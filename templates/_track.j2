{#
  Macro track(t, accent) : markup d'une track individuelle, identique au
  markup inline historique de templates/issue.html.j2 (track-name,
  track-meta avec la logique label/catno/format/place/year ou fallback meta,
  track-body, track-dig, track-links). Réutilisée par issue.html.j2 (blocs
  publics) et templates/circuit_fragment.html.j2 (fragments membres).

  Pas de "-" (whitespace control) sur les tags macro/endmacro : le tag et le
  premier/dernier caractère du markup sont volontairement sur la même ligne
  source pour préserver l'indentation exacte "  <div..." sans qu'un trim
  Jinja n'avale aussi les espaces (et pas seulement le saut de ligne).
#}
{% macro track(t, accent) %}  <div class="track"{% if t.slug %} id="{{ t.slug }}"{% endif %}>
    <div class="track-name">{{ t.name }}</div>
    {% if t.label or t.catno or t.year %}<div class="track-meta">{{ t.label }}{% if t.catno %} {{ t.catno }}{% endif %}{% if t.format %} · {{ t.format }}{% endif %}{% if t.place %} · {{ t.place }}{% endif %}{% if t.year %} · {{ t.year }}{% endif %}</div>
    {% elif t.meta %}<div class="track-meta">{{ t.meta }}</div>{% endif %}
    <div class="track-body">{{ t.body | safe }}</div>
    {% if t.dig %}<div class="track-dig"><span class="dig-arrow">↳</span> {{ t.dig }}</div>{% endif %}
    {% if t.links %}
    <div class="track-links">
      {% for link in t.links %}<a class="track-link" href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a>{% endfor %}
    </div>
    {% endif %}
  </div>{% endmacro %}
