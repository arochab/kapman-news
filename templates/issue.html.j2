<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KAPMAN SIGNAL N°{{ "%02d"|format(issue_num) }} — {{ tagline_plain }}</title>
<meta name="theme-color" content="#0D0D0D">
<link rel="manifest" href="../../pwa/manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink:    #0D0D0D;
  --cream:  #F5F0E8;
  --red:    #E8372A;
  --green:  #00A650;
  --blue:   #2F57D4;
  --mid:    #B8B3AB;
  --dim:    #555;
  --border: #1A1A1A;
  --surface:#111111;
}

html { background: var(--ink); }
body {
  background: var(--ink);
  color: var(--cream);
  font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
  font-size: 16px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}

.wrap { max-width: 680px; margin: 0 auto; }

/* ── TRIPLE RULE ── */
.triple-rule { display: flex; height: 3px; width: 100%; }
.triple-rule .r { flex: 1; background: var(--red); }
.triple-rule .g { flex: 1; background: var(--green); }
.triple-rule .b { flex: 1; background: var(--blue); }

/* ── HERO ── */
.hero {
  padding: 56px 48px 48px;
  border-bottom: 1px solid var(--border);
  background: var(--ink);
}
.hero-meta {
  font-size: 10px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: #3A3A3A;
  margin-bottom: 40px;
}

.logo-block { margin-bottom: 40px; }
.logo-circles { display: flex; width: 96px; height: 56px; margin-bottom: 18px; position: relative; }
.logo-circles svg { width: 96px; height: 56px; }

.logo-wordmark {
  font-size: 44px;
  font-weight: 900;
  letter-spacing: .08em;
  color: var(--cream);
  line-height: 1;
  margin-bottom: 6px;
  text-transform: uppercase;
}

.logo-mini-rule { display: flex; height: 2px; width: 160px; margin-bottom: 8px; }
.logo-mini-rule .r { flex: 1; background: var(--red); }
.logo-mini-rule .g { flex: 1; background: var(--green); }
.logo-mini-rule .b { flex: 1; background: var(--blue); }

.logo-collective { font-size: 9px; letter-spacing: .26em; text-transform: uppercase; color: #333; }

.tagline {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -.02em;
  color: var(--cream);
  line-height: 1.15;
  margin-bottom: 12px;
}
.reading-time { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: #2A2A2A; }

/* ── SUMMARY ── */
.summary { background: var(--surface); padding: 28px 48px; border-bottom: 1px solid var(--border); }
.lbl { font-size: 9px; letter-spacing: .28em; text-transform: uppercase; margin-bottom: 16px; }
.lbl-blue  { color: var(--blue); }
.lbl-red   { color: var(--red); }
.lbl-green { color: var(--green); }

.sum-list { list-style: none; }
.sum-list li {
  padding: 8px 0 8px 20px;
  position: relative;
  font-size: 14px;
  color: var(--mid);
  border-bottom: 1px solid #161616;
}
.sum-list li:last-child { border-bottom: none; }
.sum-list li::before { content: "—"; position: absolute; left: 0; color: var(--blue); }

/* ── BODY ── */
.body-wrap { padding: 0 48px; }

/* ── SECTION ── */
.section { padding: 44px 0; border-bottom: 1px solid var(--border); }
.s-accent { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.s-bar { height: 2px; width: 28px; flex-shrink: 0; }
.s-bar-red   { background: var(--red); }
.s-bar-green { background: var(--green); }
.s-bar-blue  { background: var(--blue); }
.s-num { font-size: 9px; letter-spacing: .26em; text-transform: uppercase; color: #222; }

.section h2 {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--cream);
  margin-bottom: 28px;
}

/* ── TRACK ── */
.track { margin-bottom: 28px; padding-bottom: 28px; border-bottom: 1px solid #111; }
.track:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.track-name { font-size: 15px; font-weight: 600; color: var(--cream); margin-bottom: 2px; }
.track-meta { font-size: 11px; color: #3A3A3A; letter-spacing: .06em; margin-bottom: 8px; text-transform: uppercase; }
.track-body { font-size: 14px; color: var(--dim); line-height: 1.65; margin-bottom: 12px; }
.track-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  text-decoration: none;
  margin-right: 14px;
  transition: opacity .15s;
}
.track-link:hover { opacity: .5; }
.track-link-red   { color: var(--red); }
.track-link-green { color: var(--green); }
.track-link-blue  { color: var(--blue); }

/* ── STAT ── */
.stat { padding: 32px 48px; border-bottom: 1px solid var(--border); background: #0A0A0A; }
.stat-red   { border-left: 3px solid var(--red); }
.stat-green { border-left: 3px solid var(--green); }
.stat-blue  { border-left: 3px solid var(--blue); }
.stat-num { font-size: 72px; font-weight: 900; line-height: 1; letter-spacing: -.04em; margin-bottom: 10px; }
.stat-red   .stat-num { color: var(--red); }
.stat-green .stat-num { color: var(--green); }
.stat-blue  .stat-num { color: var(--blue); }
.stat-ctx { font-size: 14px; color: #3A3A3A; line-height: 1.65; }

/* ── SECTION BODY ── */
.s-body p { font-size: 15px; color: var(--mid); line-height: 1.75; margin-bottom: 16px; }
.s-body p:last-child { margin-bottom: 0; }
.s-body a { color: var(--blue); text-decoration: none; }
.s-body a:hover { text-decoration: underline; }
.s-body strong { color: var(--cream); font-weight: 600; }

/* ── FORWARD ── */
.forward { background: #080808; padding: 32px 48px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.forward p { font-size: 14px; color: #444; line-height: 1.8; }

/* ── SUBSCRIBE ── */
.subscribe-section { padding: 52px 48px; border-bottom: 1px solid var(--border); display: flex; gap: 40px; align-items: flex-start; }
.sub-text { flex: 1; }
.sub-text h3 { font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--cream); margin-bottom: 10px; }
.sub-text p { font-size: 13px; color: var(--dim); line-height: 1.7; margin-bottom: 20px; }
#sub-btn {
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--cream);
  background: transparent;
  border: 1px solid #2A2A2A;
  padding: 10px 20px;
  cursor: pointer;
  font-family: inherit;
  transition: all .2s;
}
#sub-btn:hover, #sub-btn.on { border-color: var(--green); color: var(--green); }
#sub-status { font-size: 12px; color: #777; margin-top: 12px; min-height: 16px; line-height: 1.5; }
#sub-status[data-kind="ok"]  { color: var(--green); }
#sub-status[data-kind="err"] { color: var(--red); }
.qr-wrap { flex-shrink: 0; text-align: center; }
.qr-wrap img { width: 96px; height: 96px; display: block; margin-bottom: 8px; image-rendering: pixelated; }
.qr-label { font-size: 9px; letter-spacing: .18em; text-transform: uppercase; color: #2A2A2A; line-height: 1.5; }

/* ── FOOTER ── */
.footer { padding: 48px 48px 60px; text-align: center; background: var(--ink); }
.footer-logo { margin-bottom: 24px; }
.footer-logo-circles { margin: 0 auto 10px; display: block; }
.footer-wordmark { font-size: 22px; font-weight: 900; letter-spacing: .1em; color: #222; text-transform: uppercase; margin-bottom: 4px; }
.footer-mini-rule { display: flex; height: 1px; width: 80px; margin: 0 auto 6px; }
.footer-mini-rule .r { flex:1; background: var(--red); }
.footer-mini-rule .g { flex:1; background: var(--green); }
.footer-mini-rule .b { flex:1; background: var(--blue); }
.footer-collective { font-size: 8px; letter-spacing: .24em; text-transform: uppercase; color: #1E1E1E; margin-bottom: 28px; }
.footer-nav { display: flex; justify-content: center; gap: 24px; margin-bottom: 24px; }
.footer-nav a { font-size: 9px; letter-spacing: .16em; text-transform: uppercase; color: #1E1E1E; text-decoration: none; transition: color .15s; }
.footer-nav a:hover { color: var(--cream); }
.footer-unsub { font-size: 11px; color: #1A1A1A; line-height: 1.6; }

@media (max-width: 600px) {
  .hero, .summary, .body-wrap, .forward,
  .subscribe-section, .footer, .stat { padding-left: 24px; padding-right: 24px; }
  .tagline { font-size: 22px; }
  .logo-wordmark { font-size: 34px; }
  .stat-num { font-size: 52px; }
  .subscribe-section { flex-direction: column; gap: 28px; }
}
</style>
</head>
<body>
<div class="wrap">

<div class="triple-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>

<!-- HERO -->
<div class="hero">
  <div class="hero-meta">{{ date_iso }} &nbsp;·&nbsp; KAPMAN SIGNAL N°{{ "%02d"|format(issue_num) }} &nbsp;·&nbsp; {{ month_label }}</div>

  <div class="logo-block">
    <svg class="logo-circles" viewBox="0 0 96 56" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;margin-bottom:14px">
      <circle cx="32" cy="28" r="26" fill="#E8372A" opacity=".9"/>
      <circle cx="48" cy="28" r="26" fill="#00A650" opacity=".85"/>
      <circle cx="64" cy="28" r="26" fill="#2F57D4" opacity=".9"/>
    </svg>
    <div class="logo-wordmark">KAPMAN</div>
    <div class="logo-mini-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>
    <div class="logo-collective">Escape Music Collective</div>
  </div>

  <div class="tagline">{{ tagline_html | safe }}</div>
  <div class="reading-time">{{ reading_time }} &nbsp;·&nbsp; {{ month_label }}</div>
</div>

<!-- SUMMARY -->
<div class="summary">
  <div class="lbl lbl-blue">Cette édition</div>
  <ul class="sum-list">
    {% for bullet in summary_bullets %}<li>{{ bullet }}</li>
    {% endfor %}
  </ul>
</div>

{#
  Le corps alterne sections et stats dans l'ordre fourni par `blocks`.
  Chaque bloc a un "type" : "section" (avec tracks ou body) ou "stat".
  Les sections "tracks" et "body" partagent la même enveloppe ; on choisit
  le rendu selon la présence de `tracks` ou `paragraphs`.
#}
{% for block in blocks %}
  {% if block.type == "section" %}
<div class="body-wrap">
<div class="section">
  <div class="s-accent"><div class="s-bar s-bar-{{ block.accent }}"></div><div class="s-num">{{ block.index }} / {{ section_count }}</div></div>
  <h2>{{ block.heading }}</h2>
    {% if block.tracks %}
    {% for t in block.tracks %}
  <div class="track">
    <div class="track-name">{{ t.name }}</div>
    {% if t.meta %}<div class="track-meta">{{ t.meta }}</div>{% endif %}
    <div class="track-body">{{ t.body | safe }}</div>
    {% for link in t.links %}<a class="track-link track-link-{{ block.accent }}" href="{{ link.url }}" target="_blank">{{ link.label }}</a>{% endfor %}
  </div>
    {% endfor %}
    {% endif %}
    {% if block.paragraphs %}
  <div class="s-body">
    {% for p in block.paragraphs %}<p>{{ p | safe }}</p>{% endfor %}
  </div>
    {% endif %}
</div>
</div>
  {% elif block.type == "stat" %}
<div class="stat stat-{{ block.accent }}">
  <div class="stat-num">{{ block.number }}</div>
  <div class="stat-ctx">{{ block.context }}</div>
</div>
  {% endif %}
{% endfor %}

<!-- FORWARD -->
<div class="forward">
  <div class="lbl lbl-red" style="margin-bottom:14px">Ce qui suit</div>
  <p>{{ forward_text | safe }}</p>
</div>

<!-- SUBSCRIBE + QR -->
<div class="subscribe-section">
  <div class="sub-text">
    <h3>Recevoir les prochaines issues</h3>
    <p>Notification push Android directement sur ton téléphone. Pas d'appli, pas de compte — Chrome + un tap. Ou scanne le QR.</p>
    <button id="sub-btn" onclick="subscribePush()">↓ S'abonner aux notifications</button>
    <p id="sub-status"></p>
  </div>
  <div class="qr-wrap">
    <img src="../../pwa/qr.png" alt="QR abonnement" onerror="this.style.display='none'">
    <div class="qr-label">Scanner<br>pour s'abonner</div>
  </div>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-logo">
    <svg class="footer-logo-circles" width="48" height="28" viewBox="0 0 96 56" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="32" cy="28" r="26" fill="#E8372A" opacity=".3"/>
      <circle cx="48" cy="28" r="26" fill="#00A650" opacity=".3"/>
      <circle cx="64" cy="28" r="26" fill="#2F57D4" opacity=".3"/>
    </svg>
    <div class="footer-wordmark">KAPMAN</div>
    <div class="footer-mini-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>
    <div class="footer-collective">Escape Music Collective</div>
  </div>

  <nav class="footer-nav">
    <a href="../../">Toutes les issues</a>
    <a href="https://github.com/arochab/kapman-news" target="_blank">GitHub</a>
  </nav>
  <div class="footer-unsub">KAPMAN SIGNAL — La newsletter du collectif.</div>
</div>

<div class="triple-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>

</div>
<script src="../../pwa/push-client.js"></script>
</body>
</html>
