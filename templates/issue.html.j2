<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KAPMAN SIGNAL N°{{ "%02d"|format(issue_num) }} — {{ tagline_plain }}</title>
<meta name="theme-color" content="#0D0D0D">
<link rel="manifest" href="../../pwa/manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<!-- Brand book : DISPLAY = Black Ops One · TEXT = Hanken Grotesk · TECHNICAL = IBM Plex Mono -->
<link href="https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Hanken+Grotesk:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* Couleurs exactes du brand book (brand_assets/) */
  --ink:    #0E0F14;
  --cream:  #F0EEE6;
  --red:    #E83A2E;
  --green:  #1FC85E;
  --blue:   #3A6CF0;
  --mid:    #B8B3AB;
  --dim:    #5A5C66;
  --border: #1B1C22;
  --surface:#121319;
  --disp:   'Black Ops One', system-ui, sans-serif;
  --text:   'Hanken Grotesk', system-ui, -apple-system, sans-serif;
  --mono:   'IBM Plex Mono', ui-monospace, monospace;
}

html { background: var(--ink); }
body {
  background: var(--ink);
  color: var(--cream);
  font-family: var(--text);
  font-size: 16px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}

.wrap { max-width: 680px; margin: 0 auto; }

/* ── TRIPLE RULE ── */
.triple-rule { display: flex; height: 3px; width: 100%; }
.triple-rule .r { flex: 1; background: var(--red); }
.triple-rule .g { flex: 1; background: var(--green); }
.triple-rule .b { flex: 1; background: var(--blue); }

/* ── HERO ── */
.hero {
  padding: 56px 48px 48px;
  border-bottom: 1px solid var(--border);
  background: var(--ink);
}
.hero-meta {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: #44464F;
  margin-bottom: 40px;
}

.logo-block { margin-bottom: 40px; }
/* Marque RGB-light : 3 disques HTML en screen → vrai mélange additif (jaune/cyan/blanc) */
.logo-circles { position: relative; width: 96px; height: 56px; margin-bottom: 18px; isolation: isolate; }
.lc {
  position: absolute; top: 0; width: 56px; height: 56px; border-radius: 50%;
  mix-blend-mode: screen; will-change: transform;
  animation: lc-breathe 6s ease-in-out infinite;
}
.lc-r { left: 0;   background: var(--red);   }
.lc-g { left: 20px; background: var(--green); animation-delay: -2s; }
.lc-b { left: 40px; background: var(--blue);  animation-delay: -4s; }
@keyframes lc-breathe {
  0%, 100% { transform: translateX(0); }
  50%      { transform: translateX(var(--shift, 0)); }
}

/* Wordmark RGB-split (SONIC MARK du brand book) ────────────────── */
.logo-wordmark {
  font-family: var(--disp);
  font-size: 52px;
  font-weight: 400;
  letter-spacing: .02em;
  color: var(--cream);
  line-height: 1;
  margin-bottom: 10px;
  text-transform: uppercase;
  position: relative;
  display: inline-block;
}
/* couches chromatiques décalées, en screen, qui glitchent */
.logo-wordmark[data-txt]::before,
.logo-wordmark[data-txt]::after {
  content: attr(data-txt);
  position: absolute; inset: 0;
  mix-blend-mode: screen;
  pointer-events: none;
}
/* chromatic edge présent en permanence (comme le SONIC MARK statique), qui glitche par à-coups */
.logo-wordmark[data-txt]::before { color: var(--red);  transform: translate(-1.5px,0); opacity:.55; animation: rgb-r 4.2s steps(1) infinite; }
.logo-wordmark[data-txt]::after  { color: var(--blue); transform: translate(1.5px,0);  opacity:.55; animation: rgb-b 4.2s steps(1) infinite; }
@keyframes rgb-r {
  0%,82%,100% { transform: translate(-1.5px,0); opacity:.55; }
  84%   { transform: translate(-5px,2px);  opacity:1; }
  88%   { transform: translate(3px,-2px);  opacity:.85; }
  91%   { transform: translate(-2px,1px);  opacity:.7; }
  94%   { transform: translate(-1.5px,0);  opacity:.55; }
}
@keyframes rgb-b {
  0%,82%,100% { transform: translate(1.5px,0); opacity:.55; }
  84%   { transform: translate(5px,-2px);  opacity:1; }
  88%   { transform: translate(-3px,2px);  opacity:.85; }
  91%   { transform: translate(2px,-1px);  opacity:.7; }
  94%   { transform: translate(1.5px,0);   opacity:.55; }
}

.logo-mini-rule { display: flex; height: 2px; width: 160px; margin-bottom: 8px; }
.logo-mini-rule .r { flex: 1; background: var(--red); }
.logo-mini-rule .g { flex: 1; background: var(--green); }
.logo-mini-rule .b { flex: 1; background: var(--blue); }

.logo-collective { font-family: var(--mono); font-size: 9px; letter-spacing: .24em; text-transform: uppercase; color: #44464F; }

.tagline {
  font-family: var(--text);
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -.02em;
  color: var(--cream);
  line-height: 1.15;
  margin-bottom: 14px;
}
.reading-time { font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: #34363E; }

/* ── SUMMARY ── */
.summary { background: var(--surface); padding: 28px 48px; border-bottom: 1px solid var(--border); }
.lbl { font-family: var(--mono); font-size: 9px; letter-spacing: .26em; text-transform: uppercase; margin-bottom: 16px; }
.lbl-blue  { color: var(--blue); }
.lbl-red   { color: var(--red); }
.lbl-green { color: var(--green); }

.sum-list { list-style: none; }
.sum-list li {
  padding: 8px 0 8px 20px;
  position: relative;
  font-size: 14px;
  color: var(--mid);
  border-bottom: 1px solid #161616;
}
.sum-list li:last-child { border-bottom: none; }
.sum-list li::before { content: "—"; position: absolute; left: 0; color: var(--accent, var(--blue)); }

/* ── BODY ── */
.body-wrap { padding: 0 48px; }

/* ── SECTION ── */
.section { padding: 44px 0; border-bottom: 1px solid var(--border); }
.s-accent { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.s-bar { height: 2px; width: 28px; flex-shrink: 0; }
.s-bar-red   { background: var(--red); }
.s-bar-green { background: var(--green); }
.s-bar-blue  { background: var(--blue); }
.s-num { font-family: var(--mono); font-size: 9px; letter-spacing: .22em; text-transform: uppercase; color: #34363E; }

.section h2 {
  font-family: var(--mono);
  font-size: 15px;
  font-weight: 500;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--cream);
  line-height: 1.3;
  margin-bottom: 28px;
}

/* ── TRACK ── */
.tracks { counter-reset: trk; }
.track {
  margin-bottom: 28px; padding: 0 0 28px 40px; position: relative;
  border-bottom: 1px solid #111;
}
.track:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.track::before {
  counter-increment: trk; content: counter(trk, decimal-leading-zero);
  position: absolute; left: 0; top: 1px;
  font-family: var(--mono);
  font-size: 10px; letter-spacing: .04em; color: #44464F;
  font-variant-numeric: tabular-nums; transition: color .2s;
}
.track:hover::before { color: var(--accent, #555); }
.track-name { font-size: 15px; font-weight: 600; color: var(--cream); margin-bottom: 2px; line-height: 1.3; }
.track-meta { font-family: var(--mono); font-size: 10px; color: #44464F; letter-spacing: .04em; margin-bottom: 8px; text-transform: uppercase; }
.track-body { font-size: 14px; color: var(--dim); line-height: 1.65; margin-bottom: 12px; }
.tracks-red   { --accent: var(--red); }
.tracks-green { --accent: var(--green); }
.tracks-blue  { --accent: var(--blue); }
.track-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .14em;
  text-transform: uppercase;
  text-decoration: none;
  margin-right: 10px;
  padding: 6px 12px;
  border: 1px solid #1E1E1E;
  border-radius: 2px;
  transition: border-color .18s, color .18s, background .18s;
}
.track-link:hover { border-color: currentColor; background: rgba(255,255,255,.02); }
.track-link-red   { color: var(--red); }
.track-link-green { color: var(--green); }
.track-link-blue  { color: var(--blue); }

/* ── STAT ── */
.stat { padding: 32px 48px; border-bottom: 1px solid var(--border); background: #0A0A0A; }
.stat-red   { border-left: 3px solid var(--red); }
.stat-green { border-left: 3px solid var(--green); }
.stat-blue  { border-left: 3px solid var(--blue); }
.stat-num { font-family: var(--mono); font-size: 64px; font-weight: 500; line-height: 1; letter-spacing: -.02em; margin-bottom: 12px; }
.stat-red   .stat-num { color: var(--red); }
.stat-green .stat-num { color: var(--green); }
.stat-blue  .stat-num { color: var(--blue); }
.stat-ctx { font-size: 14px; color: #6A6C76; line-height: 1.65; }

/* ── SECTION BODY ── */
.s-body p { font-size: 15px; color: var(--mid); line-height: 1.75; margin-bottom: 16px; }
.s-body p:last-child { margin-bottom: 0; }
.s-body a { color: var(--blue); text-decoration: none; }
.s-body a:hover { text-decoration: underline; }
.s-body strong { color: var(--cream); font-weight: 600; }

/* ── FORWARD ── */
.forward { background: #080808; padding: 32px 48px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.forward p { font-size: 14px; color: #444; line-height: 1.8; }

/* ── SUBSCRIBE (texte centré, QR centré en bas) ── */
.subscribe-section { padding: 56px 48px; border-bottom: 1px solid var(--border); text-align: center; }
.sub-text { max-width: 420px; margin: 0 auto; }
.sub-text h3 { font-family: var(--mono); font-size: 13px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--cream); margin-bottom: 12px; }
.sub-text p { font-size: 14px; color: var(--mid); line-height: 1.7; margin-bottom: 22px; }
#sub-btn {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--cream);
  background: transparent;
  border: 1px solid #2C2E36;
  padding: 11px 22px;
  cursor: pointer;
  transition: all .2s;
}
#sub-btn:hover, #sub-btn.on { border-color: var(--green); color: var(--green); }
#sub-status { font-family: var(--mono); font-size: 12px; color: #777; margin-top: 12px; min-height: 16px; line-height: 1.5; }
#sub-status[data-kind="ok"]  { color: var(--green); }
#sub-status[data-kind="err"] { color: var(--red); }
.qr-wrap { margin: 36px auto 0; padding-top: 32px; border-top: 1px solid var(--border); max-width: 200px; }
.qr-wrap img { width: 120px; height: 120px; display: block; margin: 0 auto 10px; image-rendering: pixelated; }
.qr-label { font-family: var(--mono); font-size: 9px; letter-spacing: .18em; text-transform: uppercase; color: #44464F; line-height: 1.5; }

/* ── FOOTER ── */
.footer { padding: 48px 48px 60px; text-align: center; background: var(--ink); }
.footer-logo { margin-bottom: 24px; }
.footer-logo-circles { margin: 0 auto 10px; display: block; }
.footer-wordmark { font-family: var(--disp); font-size: 22px; font-weight: 400; letter-spacing: .04em; color: #2A2C34; text-transform: uppercase; margin-bottom: 6px; }
.footer-mini-rule { display: flex; height: 1px; width: 80px; margin: 0 auto 6px; }
.footer-mini-rule .r { flex:1; background: var(--red); }
.footer-mini-rule .g { flex:1; background: var(--green); }
.footer-mini-rule .b { flex:1; background: var(--blue); }
.footer-collective { font-family: var(--mono); font-size: 8px; letter-spacing: .22em; text-transform: uppercase; color: #2A2C34; margin-bottom: 28px; }
.footer-nav { display: flex; justify-content: center; gap: 24px; margin-bottom: 24px; }
.footer-nav a { font-family: var(--mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: #2A2C34; text-decoration: none; transition: color .15s; }
.footer-nav a:hover { color: var(--cream); }
.footer-unsub { font-family: var(--mono); font-size: 11px; color: #24262E; line-height: 1.6; }

/* ── MOTION ── */
/* La triple-rule se déploie depuis le centre au chargement */
.triple-rule .r, .triple-rule .g, .triple-rule .b {
  transform: scaleX(0); transform-origin: center;
  animation: rule-grow .7s cubic-bezier(.2,.8,.2,1) forwards;
}
.triple-rule .g { animation-delay: .08s; }
.triple-rule .b { animation-delay: .16s; }
@keyframes rule-grow { to { transform: scaleX(1); } }

/* Apparition au scroll — entrée franche (rise).
   Le contenu n'est masqué QUE si JS tourne (classe .js sur <html>) : sans JS,
   ou si l'observer échoue, tout reste visible. Jamais de contenu perdu. */
.js .reveal { opacity: 0; transform: translateY(26px); transition: opacity .5s ease, transform .65s cubic-bezier(.16,1,.3,1); }
.js .reveal.in { opacity: 1; transform: none; }
/* Les stats claquent : slide latéral à l'apparition */
.js .stat.reveal { transform: translateX(-18px); transition: opacity .4s ease, transform .55s cubic-bezier(.16,1,.3,1); }
.js .stat.reveal.in { transform: none; }

@media (prefers-reduced-motion: reduce) {
  .triple-rule .r, .triple-rule .g, .triple-rule .b,
  .lc { animation: none !important; transform: none !important; }
  .logo-wordmark[data-txt]::before, .logo-wordmark[data-txt]::after { animation: none !important; }
  .js .reveal, .js .stat.reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
}

@media (max-width: 600px) {
  .hero, .summary, .body-wrap, .forward,
  .subscribe-section, .footer, .stat { padding-left: 24px; padding-right: 24px; }
  .tagline { font-size: 24px; }
  .logo-wordmark { font-size: 40px; }
  .stat-num { font-size: 52px; }
}
</style>
</head>
<body>
<div class="wrap">

<div class="triple-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>

<!-- HERO -->
<div class="hero">
  <div class="hero-meta">{{ date_iso }} &nbsp;·&nbsp; KAPMAN SIGNAL N°{{ "%02d"|format(issue_num) }} &nbsp;·&nbsp; {{ month_label }}</div>

  <div class="logo-block">
    <div class="logo-circles" aria-hidden="true">
      <span class="lc lc-r" style="--shift:-3px"></span>
      <span class="lc lc-g" style="--shift:0px"></span>
      <span class="lc lc-b" style="--shift:3px"></span>
    </div>
    <div class="logo-wordmark" data-txt="KAPMAN">KAPMAN</div>
    <div class="logo-mini-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>
    <div class="logo-collective">Escape Music Collective</div>
  </div>

  <div class="tagline">{{ tagline_html | safe }}</div>
  <div class="reading-time">{{ reading_time }} &nbsp;·&nbsp; {{ month_label }}</div>
</div>

<!-- SUMMARY -->
<div class="summary">
  <div class="lbl lbl-blue">Cette édition</div>
  <ul class="sum-list">
    {% for bullet in summary_bullets %}<li>{{ bullet }}</li>
    {% endfor %}
  </ul>
</div>

{#
  Le corps alterne sections et stats dans l'ordre fourni par `blocks`.
  Chaque bloc a un "type" : "section" (avec tracks ou body) ou "stat".
  Les sections "tracks" et "body" partagent la même enveloppe ; on choisit
  le rendu selon la présence de `tracks` ou `paragraphs`.
#}
{% for block in blocks %}
  {% if block.type == "section" %}
<div class="body-wrap">
<div class="section reveal">
  <div class="s-accent"><div class="s-bar s-bar-{{ block.accent }}"></div><div class="s-num">{{ block.index }} / {{ section_count }}</div></div>
  <h2>{{ block.heading }}</h2>
    {% if block.tracks %}
  <div class="tracks tracks-{{ block.accent }}">
    {% for t in block.tracks %}
  <div class="track">
    <div class="track-name">{{ t.name }}</div>
    {% if t.meta %}<div class="track-meta">{{ t.meta }}</div>{% endif %}
    <div class="track-body">{{ t.body | safe }}</div>
    {% for link in t.links %}<a class="track-link track-link-{{ block.accent }}" href="{{ link.url }}" target="_blank">{{ link.label }}</a>{% endfor %}
  </div>
    {% endfor %}
  </div>
    {% endif %}
    {% if block.paragraphs %}
  <div class="s-body">
    {% for p in block.paragraphs %}<p>{{ p | safe }}</p>{% endfor %}
  </div>
    {% endif %}
</div>
</div>
  {% elif block.type == "stat" %}
<div class="stat stat-{{ block.accent }} reveal">
  <div class="stat-num">{{ block.number }}</div>
  <div class="stat-ctx">{{ block.context }}</div>
</div>
  {% endif %}
{% endfor %}

<!-- FORWARD -->
<div class="forward reveal">
  <div class="lbl lbl-red" style="margin-bottom:14px">Ce qui suit</div>
  <p>{{ forward_text | safe }}</p>
</div>

<!-- SUBSCRIBE + QR (QR centré en bas) -->
<div class="subscribe-section reveal">
  <div class="sub-text">
    <h3>Recevoir les prochaines issues</h3>
    <p>Notification push Android directement sur ton téléphone. Pas d'appli, pas de compte — Chrome + un tap. Ou scanne le QR.</p>
    <button id="sub-btn" onclick="subscribePush()">↓ S'abonner aux notifications</button>
    <p id="sub-status"></p>
  </div>
  <div class="qr-wrap">
    <img src="../../pwa/qr.png" alt="QR abonnement" onerror="this.parentNode.style.display='none'">
    <div class="qr-label">Scanner pour s'abonner</div>
  </div>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-logo">
    <svg class="footer-logo-circles" width="48" height="28" viewBox="0 0 96 56" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="32" cy="28" r="26" fill="#E83A2E" opacity=".28"/>
      <circle cx="48" cy="28" r="26" fill="#1FC85E" opacity=".28"/>
      <circle cx="64" cy="28" r="26" fill="#3A6CF0" opacity=".28"/>
    </svg>
    <div class="footer-wordmark">KAPMAN</div>
    <div class="footer-mini-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>
    <div class="footer-collective">Escape Music Collective</div>
  </div>

  <nav class="footer-nav">
    <a href="../../">Toutes les issues</a>
    <a href="https://github.com/arochab/kapman-news" target="_blank">GitHub</a>
  </nav>
  <div class="footer-unsub">KAPMAN SIGNAL — La newsletter du collectif.</div>
</div>

<div class="triple-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>

</div>
<script>
(function () {
  var root = document.documentElement;
  var els = [].slice.call(document.querySelectorAll('.reveal'));
  function showAll() { els.forEach(function (el) { el.classList.add('in'); }); }

  // On n'arme le masquage que si tout est OK ; sinon le contenu reste visible.
  var reduce = false;
  try { reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

  if (reduce || !('IntersectionObserver' in window)) {
    root.classList.add('js'); showAll(); return;
  }

  try {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });

    root.classList.add('js');           // masque (via CSS) puis révèle au scroll
    els.forEach(function (el) { io.observe(el); });

    // Révèle immédiatement ce qui est déjà dans le viewport au chargement.
    requestAnimationFrame(function () {
      els.forEach(function (el) {
        var r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('in');
      });
    });

    // Filet de sécurité : quoi qu'il arrive, tout est visible après 1,2 s.
    setTimeout(showAll, 1200);
  } catch (e) {
    root.classList.remove('js'); showAll();
  }
})();
</script>
<script src="../../pwa/push-client.js"></script>
</body>
</html>
