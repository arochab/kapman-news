{%- set acc = ['red', 'green', 'blue'][issue_num % 3] -%}
{%- set acc_label = {'red': 'OR', 'green': 'CUIVRE', 'blue': 'ACIER'}[acc] -%}
{%- set listen_url = playlist_url or listen_all_url -%}
{%- import '_track.j2' as trackm -%}
{%- set site_url = "https://arochab.github.io/kapman-news/" -%}
{%- set issue_num_padded = "%02d"|format(issue_num) -%}
{%- set issue_url = site_url ~ "issues/" ~ issue_num_padded ~ "/" -%}
{%- set og_image_url = site_url ~ "issues/" ~ issue_num_padded ~ "/card.png" -%}
{%- set og_description = ((summary_bullets[0] if summary_bullets else (forward_text | striptags)) | trim) | truncate(160, True, "…") -%}
{#- date_iso "AAAA-MM-JJ" -> "JJ.MM.AA" : même registre que la home et la carte
    de partage. Fallback : la chaîne brute si le format est inattendu. -#}
{%- set date_display = date_iso[8:10] ~ "." ~ date_iso[5:7] ~ "." ~ date_iso[2:4] if date_iso and date_iso|length == 10 else date_iso -%}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CIRCUIT FERMÉ N°{{ "%02d"|format(issue_num) }} · {{ tagline_plain }}</title>
<meta name="theme-color" content="#0A0A0C">
<!-- Open Graph / Twitter Card : og_card.py génère issues/NN/card.png au build
     (tools/build_issue.py). og_image_available vient du contexte de rendu
     (og_card.py réussi) : si absent, aucune balise image n'est émise (pas
     de lien cassé), le reste (title/description/url) reste servi. -->
<meta property="og:type" content="article">
<meta property="og:locale" content="fr_FR">
<meta property="og:site_name" content="CIRCUIT FERMÉ">
<meta property="og:url" content="{{ issue_url }}">
<meta property="og:title" content="{{ tagline_plain }}">
<meta property="og:description" content="{{ og_description }}">
<meta name="twitter:title" content="{{ tagline_plain }}">
<meta name="twitter:description" content="{{ og_description }}">
{%- if og_image_available %}
<meta property="og:image" content="{{ og_image_url }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="CIRCUIT FERMÉ N°{{ issue_num_padded }} · {{ tagline_plain }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:image" content="{{ og_image_url }}">
{%- endif %}
<link rel="icon" href="../../pwa/icon-192.png" type="image/png">
<link rel="apple-touch-icon" href="../../pwa/icon-192.png">
<link rel="manifest" href="../../pwa/manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<!-- Charte v4 « société d'écoute » : DISPLAY/ÉDITORIAL = Fraunces (opsz auto,
     variable 300..700, romain + italique) · CORPS/UI = Space Grotesk ·
     TECHNIQUE = Space Mono. -->
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* Charte v4 · tokens exacts (docs charte). Zéro hex hors :root. */
  --carbone:    #0A0A0C;   /* fond */
  --graphite:   #131316;   /* surfaces, cartes */
  --hairline:   #26262B;   /* filets 1px */
  --os:         #ECE7DC;   /* texte principal / fond des panneaux inversés */
  --brume:      #9C978A;   /* texte secondaire */
  --creuse:     #6E6A60;   /* méta discrète, uniquement ≥12px ou uppercase tracké */
  --laiton:     #C2A36B;   /* accent */
  --laiton-vif: #D9BC85;   /* hover / focus */
  --terracotta: #C96C5A;   /* erreurs uniquement */
  --panel-ink:  #1A1A1C;   /* texte des panneaux --os (tokens inversés) */
  --cuivre:     #C08D6E;
  --acier:      #A9AEB8;
  /* Cycle des éditions : même mécanique issue_num % 3, même variable
     --issue-accent. acc-0 = laiton « OR » · acc-1 = cuivre « CUIVRE » ·
     acc-2 = acier « ACIER ». */
  --acc-red:    var(--laiton);
  --acc-green:  var(--cuivre);
  --acc-blue:   var(--acier);
  /* Variante des accents lisible (≥4.5:1) sur fond --os : réservée aux liens
     et emphases dans les panneaux inversés (note de studio, sections invert). */
  --acc-red-ink:   #7A5A28;
  --acc-green-ink: #7A5330;
  --acc-blue-ink:  #52565F;
  --issue-accent: var(--acc-{{ acc }});
  --issue-accent-ink: var(--acc-{{ acc }}-ink);

  --serif: 'Fraunces', Georgia, serif;
  --sans:  'Space Grotesk', system-ui, -apple-system, sans-serif;
  --mono:  'Space Mono', ui-monospace, monospace;
}

html { background: var(--carbone); scrollbar-color: var(--hairline) var(--carbone); }
body {
  background: var(--carbone);
  color: var(--os);
  font-family: var(--sans);
  font-size: 16.5px;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}

::selection { background: var(--laiton); color: var(--carbone); }

a { color: inherit; }
a:focus-visible, button:focus-visible, input:focus-visible { outline: 2px solid var(--laiton); outline-offset: 3px; }

::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: var(--carbone); }
::-webkit-scrollbar-thumb { background: var(--hairline); border-radius: 6px; }
::-webkit-scrollbar-thumb:hover { background: var(--laiton); }

.wrap { max-width: 720px; margin: 0 auto; counter-reset: trk; }

/* ── LE SILLON (motif signature) ──
   Arcs concentriques SVG inline : hairline pour la trame, 3 anneaux en
   accent d'édition. Remplace la triple-rule R/V/B partout : tête de page
   (sous le header), signature de la note de studio, pied de page. */
.sillon-mark circle { fill: none; stroke: var(--hairline); stroke-width: 1; }
.sillon-mark circle.acc { stroke: var(--issue-accent); }
.sillon { display: flex; align-items: center; gap: 18px; padding: 0 var(--gutter, 40px) 28px; }
.sillon-line { flex: 1; height: 1px; background: var(--hairline); }
.sillon .sillon-mark { width: 26px; height: 26px; flex-shrink: 0; }

/* ── SCEAU CF ── */
.seal-cf circle { fill: none; stroke: currentColor; stroke-width: 1; }
.seal-cf text { font-family: var(--mono); font-weight: 700; fill: currentColor; }

/* ── HEADER (sceau + wordmark) ── */
.site-header { display: flex; align-items: center; gap: 14px; padding: 36px var(--gutter, 40px) 26px; }
.seal-cf.header-seal { width: 32px; height: 32px; color: var(--os); flex-shrink: 0; }
.header-text { display: flex; flex-direction: column; gap: 5px; }
.header-wordmark { font-family: var(--mono); font-weight: 700; font-size: 13px; letter-spacing: .34em; text-transform: uppercase; color: var(--os); line-height: 1; }
.header-sub { font-family: var(--mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: var(--creuse); line-height: 1; }

/* ── HERO ── */
.hero {
  position: relative;
  overflow: hidden;
  padding: 8px var(--gutter, 40px) 56px;
}
.hero-content { position: relative; z-index: 1; max-width: 560px; }

/* Numéral d'issue en filigrane : Fraunces, contour subtil, hors du flux de lecture. */
.issue-numeral {
  position: absolute; right: -6px; top: -6px; z-index: 0; pointer-events: none;
  font-family: var(--serif); font-weight: 500; font-size: clamp(96px, 26vw, 190px); line-height: .85;
  color: var(--graphite); -webkit-text-stroke: 1px var(--hairline);
}

.edition-tag {
  display: flex; align-items: center; gap: 10px;
  font-family: var(--mono); font-size: 11px; letter-spacing: .22em; text-transform: uppercase;
  color: var(--creuse); margin-bottom: 22px;
}
.pastille { display: inline-block; width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }
.pastille-red   { background: var(--acc-red); }
.pastille-green { background: var(--acc-green); }
.pastille-blue  { background: var(--acc-blue); }

.tagline {
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(36px, 8.5vw, 68px);
  font-weight: 560;
  letter-spacing: -.01em;
  color: var(--os);
  line-height: 1.08;
  margin-bottom: 26px;
}
.hero-meta { font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--creuse); }
.hero-meta span { white-space: nowrap; }

/* ── SUMMARY ── */
.summary { padding: 0 var(--gutter, 40px) 40px; }
.kicker { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--laiton); margin-bottom: 18px; }

.sum-list { list-style: none; border-top: 1px solid var(--hairline); }
.sum-list li {
  padding: 14px 0 14px 20px;
  position: relative;
  font-size: 15px;
  color: var(--brume);
  border-bottom: 1px solid var(--hairline);
}
.sum-list li::before { content: "·"; position: absolute; left: 0; color: var(--laiton); font-weight: 700; }
.sum-link { color: inherit; text-decoration: none; display: block; transition: color .18s; }
.sum-link:hover, .sum-link:focus-visible { color: var(--os); }

.listen-all {
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--carbone); background: var(--laiton); border: 1px solid var(--laiton); border-radius: 999px;
  padding: 13px 26px; min-height: 44px; margin-top: 24px;
  text-decoration: none; transition: background .18s, border-color .18s;
}
.listen-all:hover, .listen-all:focus-visible { background: var(--laiton-vif); border-color: var(--laiton-vif); }
.listen-all-end-wrap { padding: 0 var(--gutter, 40px) 48px; }
.listen-all--end { margin-top: 0; }

/* ── BODY ── */
.body-wrap { padding: 0 var(--gutter, 40px); }

/* ── SECTION ── */
.section { padding: 48px 0; border-bottom: 1px solid var(--hairline); }
.s-accent { display: flex; align-items: center; gap: 12px; margin-bottom: 22px; }
.s-num { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--creuse); }

.section h2 {
  font-family: var(--serif);
  font-style: normal;
  font-size: clamp(24px, 4vw, 29px);
  font-weight: 500;
  letter-spacing: -.01em;
  color: var(--os);
  line-height: 1.28;
  margin-bottom: 30px;
}

/* ── SECTION INVERSÉE (panneau --os) · « Note de studio » & co ── */
.section--invert { background: var(--os); color: var(--panel-ink); margin: 0 calc(var(--gutter, 40px) * -1); padding: 48px var(--gutter, 40px); }
.section--invert h2 { color: var(--panel-ink); }
.section--invert .s-body p, .section--invert .s-body { color: var(--panel-ink); }
.section--invert .s-body strong, .section--invert .studio-body strong { color: var(--panel-ink); font-weight: 700; }
.section--invert .s-num { color: var(--creuse); }
.section--invert .s-body a, .section--invert .studio-body a { color: var(--issue-accent-ink); text-decoration-color: currentColor; }

/* ── NOTE DE STUDIO (panneau signature, hors flux numéroté) ──
   Panneau --os (tokens inversés) : en-tête mono, corps en Fraunces romain
   19px/1.75 (seule prose serif du site, la voix), signature = le sillon
   (arcs en accent) aligné à droite. */
.studio-kicker { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--creuse); margin-bottom: 26px; }
.studio-body p { font-family: var(--serif); font-style: normal; font-weight: 400; font-size: 19px; line-height: 1.75; color: var(--panel-ink); margin-bottom: 18px; }
.studio-body p:last-child { margin-bottom: 0; }
.studio-sig { display: flex; justify-content: flex-end; margin-top: 32px; }
.studio-sig .sillon-mark { width: 38px; height: 38px; }

/* ── TRACK ── */
.track {
  margin-bottom: 32px; padding: 0 0 32px 42px; position: relative;
  border-bottom: 1px solid var(--hairline);
}
.track:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.track:target { border-left: 2px solid var(--laiton); padding-left: 40px; }
.track::before {
  counter-increment: trk; content: counter(trk, decimal-leading-zero);
  position: absolute; left: 0; top: 2px;
  font-family: var(--mono);
  font-size: 11px; letter-spacing: .04em; color: var(--creuse);
  font-variant-numeric: tabular-nums; transition: color .2s;
}
.track:hover::before { color: var(--laiton); }
.track-name { font-family: var(--sans); font-size: 18px; font-weight: 700; color: var(--os); margin-bottom: 4px; line-height: 1.35; }
.track-meta { font-family: var(--mono); font-size: 11px; color: var(--laiton); letter-spacing: .06em; margin-bottom: 10px; text-transform: uppercase; }
.track-body { font-size: 16.5px; color: var(--brume); line-height: 1.7; margin-bottom: 14px; }
.track-body strong { color: var(--os); font-weight: 700; }
.track-dig { font-family: var(--mono); font-size: 13px; color: var(--laiton); line-height: 1.5; margin-bottom: 14px; }
.dig-arrow { margin-right: 6px; }
.track-links { display: flex; flex-wrap: wrap; gap: 10px; }
.track-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--brume);
  min-height: 44px;
  padding: 11px 18px;
  border: 1px solid var(--hairline);
  border-radius: 999px;
  transition: border-color .18s, color .18s;
}
.track-link:hover, .track-link:focus-visible { border-color: var(--laiton); color: var(--laiton); }

/* ── STAT ── */
.stat { padding: 40px var(--gutter, 40px); border-bottom: 1px solid var(--hairline); background: var(--graphite); }
.stat .pastille { margin-bottom: 16px; }
.stat-num { font-family: var(--mono); font-weight: 700; font-size: 60px; line-height: 1; letter-spacing: -.02em; color: var(--os); margin-bottom: 14px; }
.stat-ctx { font-size: 14.5px; color: var(--brume); line-height: 1.65; }

/* ── SECTION BODY ── */
.s-body p { font-size: 16.5px; color: var(--brume); line-height: 1.7; margin-bottom: 18px; }
.s-body p:last-child { margin-bottom: 0; }
.s-body a { color: var(--laiton); text-decoration: none; border-bottom: 1px solid var(--hairline); }
.s-body a:hover, .s-body a:focus-visible { border-color: var(--laiton); }
.s-body strong { color: var(--os); font-weight: 700; }

/* ── TRACKLIST RÉCAP (optionnel) ── */
.tracklist-recap-list { list-style: none; font-family: var(--mono); font-size: 12.5px; border-top: 1px solid var(--hairline); }
.tracklist-recap-list li { border-bottom: 1px solid var(--hairline); }
.tracklist-recap-list a { display: flex; align-items: center; padding: 12px 0; min-height: 44px; color: var(--brume); text-decoration: none; transition: color .18s; }
.tracklist-recap-list a:hover, .tracklist-recap-list a:focus-visible { color: var(--laiton); }

/* ── FORWARD ── */
.forward { background: var(--graphite); padding: 40px var(--gutter, 40px); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
.forward p { font-size: 15.5px; color: var(--brume); line-height: 1.8; }

{% if site and site.membership_url %}
/* ── MEMBERSHIP (Membre du circuit, optionnel) ──
   Tout ce bloc (CSS + markup) est conditionné par site.membership_url : tant
   que content/site.json ne fournit pas d'URL Stripe, rien n'en sort dans le
   HTML rendu · pas même le CSS. */
.membership { padding: 52px var(--gutter, 40px); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); text-align: center; }
.membership-title { font-family: var(--serif); font-size: clamp(23px, 4vw, 27px); font-weight: 500; color: var(--os); margin-bottom: 14px; line-height: 1.3; }
.membership p { font-size: 15.5px; color: var(--brume); line-height: 1.7; max-width: 420px; margin: 0 auto 26px; }
.membership-cta {
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--carbone); background: var(--laiton); border: 1px solid var(--laiton); border-radius: 999px;
  padding: 14px 26px; min-height: 44px;
  text-decoration: none; transition: background .18s, border-color .18s;
}
.membership-cta:hover, .membership-cta:focus-visible { background: var(--laiton-vif); border-color: var(--laiton-vif); }
.membership-alt { display: inline-block; font-family: var(--mono); font-size: 12px; color: var(--brume); text-decoration: underline; text-decoration-color: transparent; transition: color .18s, text-decoration-color .18s; margin-top: 16px; }
.membership-alt:hover, .membership-alt:focus-visible { color: var(--laiton); text-decoration-color: var(--laiton); }
.membership-note { font-family: var(--mono); font-size: 10px; color: var(--creuse); margin-top: 16px; letter-spacing: .04em; }
{% endif %}
{% if circuit %}
/* ── CIRCUIT (verrou membre = LA CARTE DE MEMBRE, contenu chiffré embarqué
   déverrouillé par code) ──
   Conditionné par `circuit` : seules les issues avec contenu membre
   embarquent ce CSS, rien n'en sort ailleurs. */
.circuit-lock {
  margin: 52px var(--gutter, 40px);
  background: var(--graphite);
  border: 1px solid var(--hairline);
  border-radius: 14px;
  padding: 44px;
  position: relative;
  overflow: hidden;
}
.lock-watermark { position: absolute; top: 18px; right: 18px; width: 84px; height: 84px; pointer-events: none; }
.lock-watermark circle { fill: none; stroke: var(--hairline); stroke-width: 1; }
.lock-watermark text { fill: var(--hairline); }
.circuit-locked { position: relative; z-index: 1; }
.lock-kicker { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--laiton); margin-bottom: 18px; }
.lock-title { font-family: var(--serif); font-style: italic; font-weight: 560; font-size: clamp(26px, 5vw, 34px); line-height: 1.2; color: var(--os); margin-bottom: 18px; max-width: 380px; }
.circuit-teaser { font-size: 15.5px; color: var(--brume); line-height: 1.7; margin-bottom: 30px; max-width: 420px; }
.circuit-form { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
.circuit-input {
  flex: 1; min-width: 180px;
  font-family: var(--mono); font-size: 13px; letter-spacing: .1em; text-transform: uppercase;
  color: var(--os); background: var(--carbone); border: 1px solid var(--hairline); border-radius: 4px;
  padding: 13px 16px; min-height: 44px;
}
.circuit-input::placeholder { color: var(--creuse); text-transform: none; letter-spacing: normal; }
.circuit-input:focus-visible { outline: 2px solid var(--laiton); outline-offset: 2px; border-color: var(--laiton); }
.circuit-submit {
  font-family: var(--mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--carbone); background: var(--laiton); border: 1px solid var(--laiton); border-radius: 4px;
  padding: 13px 24px; min-height: 44px; cursor: pointer; transition: background .18s, border-color .18s;
}
.circuit-submit:hover, .circuit-submit:focus-visible { background: var(--laiton-vif); border-color: var(--laiton-vif); }
.circuit-error { font-family: var(--mono); font-size: 11px; color: var(--terracotta); margin-top: 14px; display: none; }
.circuit-error.show { display: block; }
.circuit-membership { margin-top: 28px; padding-top: 22px; border-top: 1px solid var(--hairline); font-family: var(--mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; display: flex; flex-wrap: wrap; gap: 10px 28px; }
.circuit-membership-link { color: var(--brume); text-decoration: none; padding: 4px 0; transition: color .18s; }
.circuit-membership-link--primary { color: var(--laiton); }
.circuit-membership-link:hover, .circuit-membership-link:focus-visible { color: var(--laiton-vif); }
.circuit-open-line { display: none; align-items: center; gap: 12px; font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--laiton); position: relative; z-index: 1; }
.circuit-open-line .seal-cf { width: 26px; height: 26px; color: var(--laiton); flex-shrink: 0; }
#circuit-lock.is-open .circuit-locked { display: none; }
#circuit-lock.is-open .circuit-open-line { display: flex; }
/* Panneau ouvert : une ligne de statut seule ne justifie plus le padding
   plein d'un formulaire, on resserre pour éviter la boîte vide. */
#circuit-lock.is-open { padding: 26px 32px; }

/* Badge discret sur les fragments membres injectés (templates/circuit_fragment.html.j2) ·
   pastille métal + libellé, même registre que .s-num. */
.s-circuit { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: var(--laiton); }
@media (max-width: 600px) { .circuit-lock { padding: 28px; margin: 40px 24px; } .lock-watermark { width: 64px; height: 64px; } }
{% endif %}
/* ── SUBSCRIBE (texte centré, QR centré en bas) ── */
.subscribe-section { padding: 60px var(--gutter, 40px); border-bottom: 1px solid var(--hairline); text-align: center; }
.sub-text { max-width: 420px; margin: 0 auto; }
.sub-text h3 { font-family: var(--serif); font-size: clamp(21px, 4vw, 25px); font-weight: 500; color: var(--os); margin-bottom: 14px; }
.sub-text p { font-size: 14.5px; color: var(--brume); line-height: 1.7; margin-bottom: 26px; }
#sub-btn, #share-btn {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--os);
  background: transparent;
  border: 1px solid var(--hairline);
  border-radius: 999px;
  padding: 14px 26px;
  min-height: 44px;
  cursor: pointer;
  transition: border-color .18s, color .18s;
}
#sub-btn:hover, #sub-btn.on, #share-btn:hover { border-color: var(--laiton); color: var(--laiton); }
#share-btn { margin-top: 28px; }
.sub-note { font-family: var(--mono); font-size: 10px; color: var(--creuse); line-height: 1.6; margin-top: 16px; letter-spacing: .02em; }
#sub-status { font-family: var(--mono); font-size: 12px; color: var(--creuse); margin-top: 14px; min-height: 16px; line-height: 1.5; }
#sub-status[data-kind="ok"]  { color: var(--laiton); }
#sub-status[data-kind="err"] { color: var(--terracotta); }
.qr-wrap { margin: 44px auto 0; padding-top: 40px; border-top: 1px solid var(--hairline); max-width: 260px; }
.qr-share-lbl { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--creuse); margin-bottom: 18px; }
.qr-wrap img { width: 128px; height: 128px; display: block; margin: 0 auto 20px; image-rendering: pixelated; background: var(--os); padding: 8px; border-radius: 6px; }
.qr-steps { display: inline-flex; flex-direction: column; gap: 8px; text-align: left; }
.qr-steps span { font-family: var(--mono); font-size: 11px; color: var(--brume); line-height: 1.4; }
.qr-steps b { color: var(--laiton); font-weight: 700; margin-right: 6px; }

/* ── NAVIGATION D'ISSUE ── */
.issue-nav {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22px var(--gutter, 40px); border-top: 1px solid var(--hairline);
  font-family: var(--mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase;
}
.issue-nav a { color: var(--creuse); text-decoration: none; display: inline-flex; align-items: center; min-height: 44px; transition: color .15s; }
.issue-nav a:hover, .issue-nav a:focus-visible { color: var(--laiton); }
.issue-nav-prev, .issue-nav-next { flex: 1; }
.issue-nav-next { text-align: right; justify-content: flex-end; }
.issue-nav-next a { justify-content: flex-end; }
.issue-nav-all { flex: 1; text-align: center; }
.issue-nav-all a { justify-content: center; }

/* ── FOOTER ── */
.footer { padding: 0 var(--gutter, 40px) 56px; text-align: center; }
.footer-seal { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 28px; }
.footer-seal .seal-cf { width: 26px; height: 26px; color: var(--creuse); }
.footer-seal .header-wordmark { font-size: 12px; color: var(--brume); }
.footer-credit { font-family: var(--mono); font-size: 10px; color: var(--creuse); line-height: 1.6; margin-bottom: 6px; letter-spacing: .04em; }
.footer-links { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 4px; margin-bottom: 10px; }
.footer-link { font-family: var(--mono); font-size: 10px; letter-spacing: .06em; text-transform: uppercase; color: var(--creuse); text-decoration: none; padding: 17px 12px; display: inline-flex; align-items: center; transition: color .15s; }
.footer-link:hover, .footer-link:focus-visible { color: var(--laiton); }
.footer-colophon { font-family: var(--mono); font-size: 10px; color: var(--creuse); letter-spacing: .06em; text-transform: uppercase; line-height: 1.6; }

/* ── MOTION ──
   Reveal translateY(12px) + fondu, 600ms. Hover : filets hairline → laiton
   (géré par composant ci-dessus). Coupé entièrement en reduced-motion. */
.js .reveal { opacity: 0; transform: translateY(12px); transition: opacity .6s cubic-bezier(.22,.61,.36,1), transform .6s cubic-bezier(.22,.61,.36,1); }
.js .reveal.in { opacity: 1; transform: none; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .001ms !important; animation-iteration-count: 1 !important; transition-duration: .001ms !important; scroll-behavior: auto !important; }
  .js .reveal { opacity: 1 !important; transform: none !important; }
}

@media (max-width: 600px) {
  :root { --gutter: 24px; }
  .site-header { padding-top: 28px; padding-bottom: 20px; }
  .stat-num { font-size: 48px; }
  .lock-title { max-width: none; }
  {% if site and site.membership_url %}.membership { padding: 40px 24px; }{% endif %}
}
</style>
</head>
<body>
<div class="wrap">

<!-- HEADER -->
<header class="site-header">
  <svg class="seal-cf header-seal" viewBox="0 0 40 40" aria-hidden="true">
    <circle cx="20" cy="20" r="18"></circle>
    <text x="20" y="25" text-anchor="middle" font-size="13">CF</text>
  </svg>
  <div class="header-text">
    <div class="header-wordmark">Circuit Fermé</div>
    <div class="header-sub">société d'écoute · paris</div>
  </div>
</header>
<div class="sillon" aria-hidden="true">
  <span class="sillon-line"></span>
  <svg class="sillon-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="4"></circle><circle class="acc" cx="20" cy="20" r="7"></circle><circle cx="20" cy="20" r="10"></circle><circle class="acc" cx="20" cy="20" r="13"></circle><circle cx="20" cy="20" r="16"></circle><circle class="acc" cx="20" cy="20" r="19"></circle></svg>
  <span class="sillon-line"></span>
</div>

<!-- HERO -->
<div class="hero" data-flow="0">
  <div class="issue-numeral" aria-hidden="true">Nº{{ '%02d'|format(issue_num) }}</div>
  <div class="hero-content">
    <div class="edition-tag"><span class="pastille pastille-{{ acc }}" aria-hidden="true"></span><span>Édition Nº{{ '%02d'|format(issue_num) }} · {{ acc_label }}</span></div>
    <h1 class="tagline">{{ tagline_html | safe }}</h1>
    <div class="hero-meta"><span>CIRCUIT FERMÉ N°{{ "%02d"|format(issue_num) }}</span> <span>· {{ date_display }}</span> {% if listening_time %}<span>· Lecture {{ reading_time }}</span> <span>· Écoute {{ listening_time }}</span>{% else %}<span>· Lecture {{ reading_time }}</span>{% endif %}</div>
  </div>
</div>

<!-- SUMMARY -->
<div class="summary">
  <div class="kicker">Cette édition</div>
  <ul class="sum-list">
    {% for bullet in summary_bullets %}<li>{% if loop.index <= section_count %}<a class="sum-link" href="#s{{ loop.index }}">{{ bullet }}</a>{% else %}{{ bullet }}{% endif %}</li>
    {% endfor %}
  </ul>
  {% if listen_url %}<a class="listen-all" href="{{ listen_url }}" target="_blank" rel="noopener">▶ Écouter la sélection{% if listen_count %} · {{ listen_count }} tracks{% endif %}</a>{% endif %}
</div>

{#
  Le corps alterne sections et stats dans l'ordre fourni par `blocks`.
  Chaque bloc a un "type" : "section" (avec tracks ou body) ou "stat".
  Les sections "tracks" et "body" partagent la même enveloppe ; on choisit
  le rendu selon la présence de `tracks` ou `paragraphs`.
#}
{% for block in blocks %}
  {% if block.type == "section" and block.heading == 'Note de studio' %}
<div class="body-wrap" data-flow="{{ loop.index }}">
<div class="section studio-note reveal section--invert" id="s{{ block.index }}">
  <div class="studio-kicker">Note de studio · {{ month_label }}</div>
  <div class="s-body studio-body">
    {% for p in block.paragraphs %}<p>{{ p | safe }}</p>{% endfor %}
  </div>
  <div class="studio-sig">
    <svg class="sillon-mark" viewBox="0 0 40 40" aria-hidden="true"><circle cx="20" cy="20" r="4"></circle><circle class="acc" cx="20" cy="20" r="7"></circle><circle cx="20" cy="20" r="10"></circle><circle class="acc" cx="20" cy="20" r="13"></circle><circle cx="20" cy="20" r="16"></circle><circle class="acc" cx="20" cy="20" r="19"></circle></svg>
  </div>
</div>
</div>
  {% elif block.type == "section" %}
<div class="body-wrap" data-flow="{{ loop.index }}">
<div class="section reveal{% if block.invert %} section--invert{% endif %}" id="s{{ block.index }}">
  <div class="s-accent"><span class="pastille pastille-{{ block.accent }}" aria-hidden="true"></span><span class="s-num">{{ '%02d'|format(block.index) }} / {{ '%02d'|format(section_count) }}</span></div>
  <h2>{{ block.heading }}</h2>
    {% if block.tracks %}
  <div class="tracks tracks-{{ block.accent }}">
    {% for t in block.tracks %}
{{ trackm.track(t, block.accent) }}
    {% endfor %}
  </div>
    {% endif %}
    {% if block.paragraphs %}
  <div class="s-body">
    {% for p in block.paragraphs %}<p>{{ p | safe }}</p>{% endfor %}
  </div>
    {% endif %}
</div>
</div>
  {% elif block.type == "stat" %}
<div class="stat reveal" data-flow="{{ loop.index }}">
  <span class="pastille pastille-{{ block.accent }}" aria-hidden="true"></span>
  <div class="stat-num">{{ block.number }}</div>
  <div class="stat-ctx">{{ block.context }}</div>
</div>
  {% endif %}
{% endfor %}
{% if circuit %}
<!-- BLOC VERROU (circuit fermé) = LA CARTE DE MEMBRE -->
<div id="circuit-lock" class="circuit-lock reveal">
  <svg class="lock-watermark" viewBox="0 0 40 40" aria-hidden="true">
    <circle cx="20" cy="20" r="18"></circle>
    <text x="20" y="25" text-anchor="middle" font-family="'Space Mono', monospace" font-weight="700" font-size="13" fill="currentColor">CF</text>
  </svg>
  <div class="circuit-locked">
    <div class="lock-kicker">Réservé aux membres</div>
    <div class="lock-title">Ici, le circuit se ferme.</div>
    <p class="circuit-teaser">{{ circuit.teaser or "La suite de ce numéro reste dans le circuit, réservée aux membres." }}</p>
    <form id="circuit-form" class="circuit-form" autocomplete="off">
      <input id="circuit-code" class="circuit-input" type="text" autocomplete="off" placeholder="Numéro de membre" aria-label="Code du circuit">
      <button type="submit" class="circuit-submit">Entrer</button>
    </form>
    <p class="circuit-error" role="alert">Ce code n'ouvre rien.</p>
    {% if site and site.membership_url %}
    <div class="circuit-membership">
      <a class="circuit-membership-link circuit-membership-link--primary" href="{{ site.membership_url }}" target="_blank" rel="noopener">Devenir membre · {{ site.membership_price or '5 € par mois' }}</a>
      {% if site.membership_annual_url %}<a class="circuit-membership-link" href="{{ site.membership_annual_url }}" target="_blank" rel="noopener">ou {{ site.membership_annual_price or "50 € l'année" }}, l'objet de décembre compris</a>{% endif %}
    </div>
    {% endif %}
  </div>
  <div class="circuit-open-line">
    <svg class="seal-cf" viewBox="0 0 40 40" aria-hidden="true"><circle cx="20" cy="20" r="18"></circle><text x="20" y="25" text-anchor="middle" font-size="13">CF</text></svg>
    <span>Membre reconnu · code retenu sur cet appareil</span>
  </div>
</div>
<script type="application/json" id="circuit-blob">{{ circuit | tojson }}</script>
{% endif %}
<!-- TRACKLIST RÉCAP (optionnel, flag racine show_tracklist) -->
{% if show_tracklist %}
<div class="body-wrap">
<div class="section reveal">
  <div class="kicker">Tracklist</div>
  <ol class="tracklist-recap-list">
    {% set ns = namespace(i=0) %}
    {% for block in blocks %}
      {% if block.tracks %}
        {% for t in block.tracks %}
          {% set ns.i = ns.i + 1 %}
  <li><a href="#{{ t.slug }}">{{ '%02d'|format(ns.i) }} {{ t.name }}</a></li>
        {% endfor %}
      {% endif %}
    {% endfor %}
  </ol>
</div>
</div>
{% endif %}

<!-- ÉCOUTER LA SÉLECTION (répété avant le forward) -->
{% if listen_url %}
<div class="listen-all-end-wrap">
  <a class="listen-all listen-all--end" href="{{ listen_url }}" target="_blank" rel="noopener">▶ Écouter la sélection{% if listen_count %} · {{ listen_count }} tracks{% endif %}</a>
</div>
{% endif %}

<!-- FORWARD -->
<div class="forward reveal">
  <div class="kicker" style="margin-bottom:14px">Ce qui suit</div>
  <p>{{ forward_text | safe }}</p>
</div>

{% if site and site.membership_url and not circuit %}
<!-- MEMBERSHIP (Membre du circuit · masqué tant que content/site.json n'a pas d'URL Stripe,
     ou si l'issue a un circuit fermé : la version compacte est déjà dans le bloc verrou) -->
<div class="membership reveal">
  <div class="kicker">Soutenir</div>
  <h3 class="membership-title">Membre du circuit</h3>
  <p>La lettre reste gratuite. Les membres financent la suite et débloquent la Séance d'écoute mensuelle, le crate du mois avec ses tracks bonus, et l'objet de fin d'année pour les annuels.</p>
  <a class="membership-cta" href="{{ site.membership_url }}" target="_blank" rel="noopener">Devenir membre · {{ site.membership_price or '5 € / mois' }}</a>
  {% if site.membership_annual_url %}
  <div><a class="membership-alt" href="{{ site.membership_annual_url }}" target="_blank" rel="noopener">ou l'année · {{ site.membership_annual_price or '50 € / an' }}</a></div>
  {% endif %}
  <p class="membership-note">Sans engagement · résiliable en un clic.</p>
</div>
{% endif %}

<!-- SUBSCRIBE + QR (QR = partage à un ami, parcours honnête) -->
<div class="subscribe-section reveal">
  <div class="sub-text">
    <h3>Recevoir les prochaines éditions</h3>
    <p>Une notification sur votre téléphone Android, deux fois par semaine. Pas d'application, pas de compte&nbsp;: Chrome suffit.</p>
    <button id="sub-btn" onclick="subscribePush()">↓ S'abonner aux notifications</button>
    <p class="sub-note">Vous pouvez couper quand vous voulez · le même bouton sert à vous désabonner.</p>
    <p id="sub-status" aria-live="polite"></p>
  </div>
  <button id="share-btn" hidden>↗ Partager à un ami</button>
  <div class="qr-wrap">
    <div class="qr-share-lbl">Partager à un ami</div>
    <img src="../../pwa/qr.png" alt="QR vers CIRCUIT FERMÉ" onerror="this.parentNode.style.display='none'">
    <div class="qr-steps">
      <span><b>1.</b> Scannez avec l'appareil photo</span>
      <span><b>2.</b> Ouvrez le lien dans Chrome</span>
      <span><b>3.</b> Appuyez sur « S'abonner »</span>
    </div>
  </div>
</div>

<!-- NAVIGATION D'ISSUE -->
<div class="issue-nav">
  <span class="issue-nav-prev">{% if prev_num %}<a href="../{{ prev_num }}/">← N°{{ prev_num }}</a>{% endif %}</span>
  <span class="issue-nav-all"><a href="../../">Tous les numéros</a></span>
  <span class="issue-nav-next">{% if next_num %}<a href="../{{ next_num }}/">N°{{ next_num }} →</a>{% endif %}</span>
</div>

<!-- FOOTER -->
<div class="sillon" aria-hidden="true">
  <span class="sillon-line"></span>
  <svg class="sillon-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="4"></circle><circle class="acc" cx="20" cy="20" r="7"></circle><circle cx="20" cy="20" r="10"></circle><circle class="acc" cx="20" cy="20" r="13"></circle><circle cx="20" cy="20" r="16"></circle><circle class="acc" cx="20" cy="20" r="19"></circle></svg>
  <span class="sillon-line"></span>
</div>
<div class="footer">
  <div class="footer-seal">
    <svg class="seal-cf" viewBox="0 0 40 40" aria-hidden="true"><circle cx="20" cy="20" r="18"></circle><text x="20" y="25" text-anchor="middle" font-size="13">CF</text></svg>
    <div class="header-wordmark">Circuit Fermé</div>
  </div>

  <div class="footer-credit">Sélection · KAPMAN</div>
  <div class="footer-links">
    <a class="footer-link" href="https://shotgun.live/artists/kapman_music" target="_blank" rel="noopener">Shotgun</a>
    <a class="footer-link" href="https://soundcloud.com/kapman_music" target="_blank" rel="noopener">SoundCloud</a>
    <a class="footer-link" href="https://www.instagram.com/kapman___/" target="_blank" rel="noopener">Instagram</a>
  </div>
  {% set track_count = blocks | selectattr('tracks', 'defined') | map(attribute='tracks') | map('length') | sum %}
  <div class="footer-colophon">N°{{ '%02d'|format(issue_num) }} · {{ month_label|upper }} · {{ track_count }} TRACKS · PARIS · CIRCUIT FERMÉ</div>
</div>

</div>
<script>
(function () {
  var root = document.documentElement;
  var els = [].slice.call(document.querySelectorAll('.reveal'));
  function showAll() { els.forEach(function (el) { el.classList.add('in'); }); }

  // On n'arme le masquage que si tout est OK ; sinon le contenu reste visible.
  var reduce = false;
  try { reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

  if (reduce || !('IntersectionObserver' in window)) {
    root.classList.add('js'); showAll(); return;
  }

  try {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });

    root.classList.add('js');           // masque (via CSS) puis révèle au scroll
    els.forEach(function (el) { io.observe(el); });

    // Révèle immédiatement ce qui est déjà dans le viewport au chargement.
    requestAnimationFrame(function () {
      els.forEach(function (el) {
        var r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('in');
      });
    });

    // Filet de sécurité : quoi qu'il arrive, tout est visible après 1,2 s.
    setTimeout(showAll, 1200);
  } catch (e) {
    root.classList.remove('js'); showAll();
  }
})();
</script>
{% if circuit %}<script src="../../pwa/circuit.js" defer></script>
{% endif -%}
<script src="../../pwa/push-client.js"></script>
</body>
</html>
