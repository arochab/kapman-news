{%- set acc = ['red', 'green', 'blue'][issue_num % 3] -%}
{%- set listen_url = playlist_url or listen_all_url -%}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CIRCUIT FERMÉ N°{{ "%02d"|format(issue_num) }} · {{ tagline_plain }}</title>
<meta name="theme-color" content="#0E0F14">
<link rel="manifest" href="../../pwa/manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<!-- Brand book : SIGNAL = glyphe 3 barres R/V/B · TEXT = Hanken Grotesk · TECHNICAL = IBM Plex Mono -->
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* Couleurs exactes du brand book (brand_assets/) */
  --ink:    #0E0F14;
  --cream:  #F0EEE6;
  --red:    #E83A2E;
  --green:  #1FC85E;
  --blue:   #3A6CF0;
  --mid:    #B8B3AB;
  --dim:    #9A9DA8;          /* corrigé pour 7.1:1 de contraste sur --ink */
  --meta:   #8A8D99;          /* corrigé pour 5.8:1 de contraste sur --ink */
  --faint:  #8B8E99;          /* corrigé pour 5.9:1 de contraste sur --ink */
  --border: #1B1C22;
  --border-strong: #2A2C36;
  --surface:#121319;
  --deep:   #0B0C10;          /* fond le plus sombre (stat, forward) */
  --blue-text: #5B85F5;       /* liens dans le texte (5.6:1) ; #3A6CF0 reste pour le graphique */
  --ink-soft: #3A3B42;        /* registre cream (section--invert) */
  --ink-meta: #6B6D78;        /* registre cream (section--invert) */
  --text:   'Hanken Grotesk', system-ui, -apple-system, sans-serif;
  --mono:   'IBM Plex Mono', ui-monospace, monospace;
  --issue-accent: var(--{{ acc }});
}

html { background: var(--ink); }
body {
  background: var(--ink);
  color: var(--cream);
  font-family: var(--text);
  font-size: 16px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}

::selection { background: var(--issue-accent, var(--blue)); color: var(--ink); }

a:focus-visible, button:focus-visible { outline: 2px solid var(--accent, var(--blue)); outline-offset: 3px; }

.wrap { max-width: 680px; margin: 0 auto; counter-reset: trk; }

/* ── TRIPLE RULE ── */
.triple-rule { display: flex; height: 3px; width: 100%; }
.triple-rule .r { flex: 1; background: var(--red); }
.triple-rule .g { flex: 1; background: var(--green); }
.triple-rule .b { flex: 1; background: var(--blue); }

/* ── HERO ── */
.hero {
  position: relative;
  overflow: hidden;
  padding: 56px 48px 48px;
  border-bottom: 1px solid var(--border);
  background: var(--ink);
}
.hero-content { position: relative; z-index: 1; }

/* Numéral d'issue géant · un seul geste géant par hero, contour simple (pas de split RGB) */
.issue-numeral {
  position: absolute; right: -8px; top: 28px; z-index: 0; pointer-events: none;
  font-family: var(--text); font-weight: 800; font-size: clamp(96px, 24vw, 180px); line-height: .85;
  color: transparent; -webkit-text-stroke: 1px var(--issue-accent); opacity: .35;
}

.hero-meta {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--meta);
  margin-bottom: 40px;
}

.logo-block { margin-bottom: 40px; }

/* ── SIGNAL GLYPH + WORDMARK LOCKUP ──
   Glyphe = 3 barres arrondies R/V/B qui respirent légèrement (scaleY, bas ancré).
   Wordmark = CIRCUIT (Hanken 800) au-dessus de FERMÉ (Plex Mono, tracking large). */
.lockup { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }

.signal-glyph { display: flex; align-items: flex-end; gap: 5px; }
.signal-glyph .sg-bar { width: 6px; border-radius: 3px; transform-origin: bottom; }
.signal-glyph .sg-r { background: var(--red);   height: 12px; animation: sg-breathe 2.8s ease-in-out infinite alternate; }
.signal-glyph .sg-g { background: var(--green); height: 22px; animation: sg-breathe 3.6s ease-in-out infinite alternate; }
.signal-glyph .sg-b { background: var(--blue);  height: 17px; animation: sg-breathe 3.2s ease-in-out infinite alternate; }
@keyframes sg-breathe { from { transform: scaleY(1); } to { transform: scaleY(.75); } }
.signal-glyph.paused .sg-bar { animation-play-state: paused; }

.lockup-text { display: flex; flex-direction: column; gap: 4px; }
.wordmark { font-family: var(--text); font-weight: 800; letter-spacing: .04em; text-transform: uppercase; color: var(--cream); line-height: 1; }
.signal-label { font-family: var(--mono); font-weight: 500; letter-spacing: .45em; text-transform: uppercase; color: var(--meta); line-height: 1; }
.logo-block .wordmark { font-size: 26px; }
.logo-block .signal-label { font-size: 9px; }

.logo-mini-rule { display: flex; height: 2px; width: 160px; margin-bottom: 8px; }
.logo-mini-rule .r { flex: 1; background: var(--red); }
.logo-mini-rule .g { flex: 1; background: var(--green); }
.logo-mini-rule .b { flex: 1; background: var(--blue); }

.logo-collective { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--meta); }

.tagline {
  font-family: var(--text);
  font-size: clamp(34px, 7vw, 46px);
  font-weight: 800;
  letter-spacing: -.03em;
  color: var(--cream);
  line-height: 1.05;
  margin-bottom: 14px;
}
.reading-time { font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--meta); }

/* ── SUMMARY ── */
.summary { background: var(--surface); padding: 28px 48px; border-bottom: 1px solid var(--border); }
.lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; margin-bottom: 16px; }
.lbl-blue   { color: var(--blue); }
.lbl-red    { color: var(--red); }
.lbl-green  { color: var(--green); }
.lbl-accent { color: var(--issue-accent); }

.sum-list { list-style: none; }
.sum-list li {
  padding: 10px 0 10px 20px;
  position: relative;
  font-size: 14px;
  color: var(--mid);
  border-bottom: 1px solid var(--border);
}
.sum-list li:last-child { border-bottom: none; }
.sum-list li::before { content: "·"; position: absolute; left: 0; color: var(--accent, var(--blue)); }
.sum-link { color: inherit; text-decoration: none; display: block; }
.sum-link:hover, .sum-link:focus-visible { color: var(--cream); }

.listen-all {
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
  color: var(--issue-accent); border: 1px solid var(--issue-accent);
  padding: 13px 20px; min-height: 44px; margin-top: 18px;
  text-decoration: none; transition: background .18s, color .18s;
}
.listen-all:hover { background: var(--issue-accent); color: var(--ink); }
.listen-all-end-wrap { padding: 0 48px 44px; }
.listen-all--end { margin-top: 0; }

/* ── BODY ── */
.body-wrap { padding: 0 48px; }

/* ── SECTION ── */
.section { padding: 44px 0; border-bottom: 1px solid var(--border); }
.s-accent { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.s-bar { height: 2px; width: 28px; flex-shrink: 0; }
.s-bar-red   { background: var(--red); }
.s-bar-green { background: var(--green); }
.s-bar-blue  { background: var(--blue); }
.s-num { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--meta); }

.section h2 {
  font-family: var(--text);
  font-size: 21px;
  font-weight: 700;
  letter-spacing: -.015em;
  text-transform: none;
  color: var(--cream);
  line-height: 1.3;
  margin-bottom: 28px;
}

/* ── SECTION INVERSÉE (cream) · "Note de studio" & co ── */
.section--invert { background: var(--cream); color: var(--ink); margin: 0 -48px; padding: 44px 48px; }
.section--invert h2 { color: var(--ink); }
.section--invert .s-body p { color: var(--ink-soft); }
.section--invert .s-num { color: var(--ink-meta); }
.section--invert .s-body a { color: var(--blue); }

/* ── TRACK ── */
.track {
  margin-bottom: 28px; padding: 0 0 28px 40px; position: relative;
  border-bottom: 1px solid var(--border);
}
.track:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.track:target { border-left: 2px solid var(--accent, var(--blue)); padding-left: 38px; }
.track::before {
  counter-increment: trk; content: counter(trk, decimal-leading-zero);
  position: absolute; left: 0; top: 1px;
  font-family: var(--mono);
  font-size: 10px; letter-spacing: .04em; color: var(--meta);
  font-variant-numeric: tabular-nums; transition: color .2s;
}
.track:hover::before { color: var(--accent, #555); }
.track-name { font-size: 15px; font-weight: 600; color: var(--cream); margin-bottom: 2px; line-height: 1.3; }
.track-meta { font-family: var(--mono); font-size: 10px; color: var(--meta); letter-spacing: .04em; margin-bottom: 8px; text-transform: uppercase; }
.track-body { font-size: 15px; color: var(--mid); line-height: 1.65; margin-bottom: 12px; }
.track-dig { font-family: var(--mono); font-size: 10px; color: var(--meta); line-height: 1.5; margin-bottom: 12px; }
.dig-arrow { color: var(--accent, var(--blue)); margin-right: 4px; }
.tracks-red   { --accent: var(--red); }
.tracks-green { --accent: var(--green); }
.tracks-blue  { --accent: var(--blue); }
.track-links { display: flex; flex-wrap: wrap; gap: 8px; }
.track-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  text-decoration: none;
  min-height: 44px;
  padding: 11px 16px;
  border: 1px solid var(--border-strong);
  border-radius: 2px;
  transition: border-color .18s, color .18s, background .18s;
}
.track-link:hover { border-color: currentColor; background: rgba(255,255,255,.02); }
.track-link-red   { color: var(--red); }
.track-link-green { color: var(--green); }
.track-link-blue  { color: var(--blue); }

/* ── STAT ── */
.stat { padding: 32px 48px; border-bottom: 1px solid var(--border); background: var(--deep); }
.stat-red   { border-left: 3px solid var(--red); }
.stat-green { border-left: 3px solid var(--green); }
.stat-blue  { border-left: 3px solid var(--blue); }
.stat-num { font-family: var(--mono); font-size: 64px; font-weight: 500; line-height: 1; letter-spacing: -.02em; margin-bottom: 12px; }
.stat-red   .stat-num { color: var(--red); }
.stat-green .stat-num { color: var(--green); }
.stat-blue  .stat-num { color: var(--blue); }
.stat-ctx { font-size: 14px; color: var(--dim); line-height: 1.65; }

/* ── SECTION BODY ── */
.s-body p { font-size: 15px; color: var(--mid); line-height: 1.75; margin-bottom: 16px; }
.s-body p:last-child { margin-bottom: 0; }
.s-body a { color: var(--blue-text); text-decoration: none; }
.s-body a:hover { text-decoration: underline; }
.s-body strong { color: var(--cream); font-weight: 600; }

/* ── TRACKLIST RÉCAP (optionnel) ── */
.tracklist-recap-list { list-style: none; font-family: var(--mono); font-size: 12px; }
.tracklist-recap-list li { border-bottom: 1px solid var(--border); }
.tracklist-recap-list li:last-child { border-bottom: none; }
.tracklist-recap-list a { display: block; padding: 10px 0; min-height: 44px; display: flex; align-items: center; color: var(--mid); text-decoration: none; }
.tracklist-recap-list a:hover, .tracklist-recap-list a:focus-visible { color: var(--cream); }

/* ── FORWARD ── */
.forward { background: var(--deep); padding: 32px 48px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.forward p { font-size: 15px; color: var(--mid); line-height: 1.8; }

{% if site and site.membership_url %}
/* ── MEMBERSHIP (Membre du circuit, optionnel) ──
   Tout ce bloc (CSS + markup) est conditionné par site.membership_url : tant
   que content/site.json ne fournit pas d'URL Stripe, rien n'en sort dans le
   HTML rendu · pas même le CSS. */
.membership { background: var(--surface); padding: 44px 48px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); text-align: center; }
.membership-title { font-family: var(--text); font-size: 21px; font-weight: 700; color: var(--cream); margin-bottom: 12px; line-height: 1.3; }
.membership p { font-size: 15px; color: var(--mid); line-height: 1.7; max-width: 420px; margin: 0 auto 22px; }
.membership-cta {
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--cream); border: 1px solid var(--cream);
  padding: 14px 24px; min-height: 44px;
  text-decoration: none; transition: border-color .18s, color .18s;
}
.membership-cta:hover, .membership-cta:focus-visible { border-color: var(--issue-accent); color: var(--issue-accent); }
.membership-alt { display: inline-block; font-family: var(--mono); font-size: 12px; color: var(--meta); text-decoration: underline; text-decoration-color: transparent; transition: color .18s, text-decoration-color .18s; margin-top: 14px; }
.membership-alt:hover, .membership-alt:focus-visible { color: var(--issue-accent); text-decoration-color: var(--issue-accent); }
.membership-note { font-family: var(--mono); font-size: 10px; color: var(--faint); margin-top: 14px; }
{% endif %}

/* ── SUBSCRIBE (texte centré, QR centré en bas) ── */
.subscribe-section { padding: 56px 48px; border-bottom: 1px solid var(--border); text-align: center; }
.sub-text { max-width: 420px; margin: 0 auto; }
.sub-text h3 { font-family: var(--mono); font-size: 13px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--cream); margin-bottom: 12px; }
.sub-text p { font-size: 14px; color: var(--mid); line-height: 1.7; margin-bottom: 22px; }
#sub-btn, #share-btn {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--cream);
  background: transparent;
  border: 1px solid var(--border-strong);
  padding: 14px 24px;
  min-height: 44px;
  cursor: pointer;
  transition: all .2s;
}
#sub-btn:hover, #sub-btn.on, #share-btn:hover { border-color: var(--green); color: var(--green); }
#share-btn { margin-top: 24px; }
.sub-note { font-family: var(--mono); font-size: 10px; color: var(--faint); line-height: 1.6; margin-top: 14px; }
#sub-status { font-family: var(--mono); font-size: 12px; color: var(--meta); margin-top: 12px; min-height: 16px; line-height: 1.5; }
#sub-status[data-kind="ok"]  { color: var(--green); }
#sub-status[data-kind="err"] { color: var(--red); }
.qr-wrap { margin: 40px auto 0; padding-top: 36px; border-top: 1px solid var(--border); max-width: 260px; }
.qr-share-lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--faint); margin-bottom: 16px; }
.qr-wrap img { width: 128px; height: 128px; display: block; margin: 0 auto 18px; image-rendering: pixelated; background: var(--cream); padding: 8px; border-radius: 4px; }
.qr-steps { display: inline-flex; flex-direction: column; gap: 7px; text-align: left; }
.qr-steps span { font-family: var(--mono); font-size: 11px; color: var(--dim); line-height: 1.4; }
.qr-steps b { color: var(--green); font-weight: 500; margin-right: 6px; }

/* ── NAVIGATION D'ISSUE ── */
.issue-nav {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20px 48px; border-top: 1px solid var(--border);
  font-family: var(--mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase;
}
.issue-nav a { color: var(--faint); text-decoration: none; display: inline-flex; align-items: center; min-height: 44px; transition: color .15s; }
.issue-nav a:hover { color: var(--cream); }
.issue-nav-prev, .issue-nav-next { flex: 1; }
.issue-nav-next { text-align: right; justify-content: flex-end; }
.issue-nav-next a { justify-content: flex-end; }
.issue-nav-all { flex: 1; text-align: center; }
.issue-nav-all a { justify-content: center; }

/* ── FOOTER ── */
.footer { padding: 48px 48px 60px; text-align: center; background: var(--ink); }
.footer-logo { margin-bottom: 24px; }
.footer-lockup { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 8px; }
.footer-lockup .signal-glyph { gap: 3px; }
.footer-lockup .sg-bar { width: 4px; }
.footer-lockup .lockup-text { gap: 2px; }
.footer-lockup .wordmark { font-size: 18px; color: var(--dim); }
.footer-lockup .signal-label { font-size: 9px; }
.footer-mini-rule { display: flex; height: 1px; width: 80px; margin: 0 auto 6px; }
.footer-mini-rule .r { flex:1; background: var(--red); }
.footer-mini-rule .g { flex:1; background: var(--green); }
.footer-mini-rule .b { flex:1; background: var(--blue); }
.footer-collective { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--faint); margin-bottom: 28px; }
.footer-credit { font-family: var(--mono); font-size: 10px; color: var(--faint); line-height: 1.6; margin-bottom: 4px; }
.footer-links { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
.footer-link { font-family: var(--mono); font-size: 10px; letter-spacing: .06em; text-transform: uppercase; color: var(--faint); text-decoration: none; padding: 17px 12px; display: inline-flex; align-items: center; transition: color .15s; }
.footer-link:hover, .footer-link:focus-visible { color: var(--cream); }
.footer-colophon { font-family: var(--mono); font-size: 10px; color: var(--meta); letter-spacing: .06em; text-transform: uppercase; line-height: 1.6; }

/* ── MOTION ── */
/* La triple-rule se déploie depuis le centre au chargement */
.triple-rule .r, .triple-rule .g, .triple-rule .b {
  transform: scaleX(0); transform-origin: center;
  animation: rule-grow .7s cubic-bezier(.2,.8,.2,1) forwards;
}
.triple-rule .g { animation-delay: .08s; }
.triple-rule .b { animation-delay: .16s; }
@keyframes rule-grow { to { transform: scaleX(1); } }

/* Apparition au scroll · entrée franche (rise).
   Le contenu n'est masqué QUE si JS tourne (classe .js sur <html>) : sans JS,
   ou si l'observer échoue, tout reste visible. Jamais de contenu perdu. */
.js .reveal { opacity: 0; transform: translateY(26px); transition: opacity .5s ease, transform .65s cubic-bezier(.16,1,.3,1); }
.js .reveal.in { opacity: 1; transform: none; }
/* Les stats claquent : slide latéral à l'apparition */
.js .stat.reveal { transform: translateX(-18px); transition: opacity .4s ease, transform .55s cubic-bezier(.16,1,.3,1); }
.js .stat.reveal.in { transform: none; }

@media (prefers-reduced-motion: reduce) {
  .triple-rule .r, .triple-rule .g, .triple-rule .b,
  .signal-glyph .sg-bar { animation: none !important; transform: none !important; }
  .js .reveal, .js .stat.reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
}

@media (max-width: 600px) {
  .hero, .summary, .body-wrap, .forward,
  .subscribe-section, .footer, .stat,
  .issue-nav, .listen-all-end-wrap { padding-left: 24px; padding-right: 24px; }
  {% if site and site.membership_url %}.membership { padding: 24px; }{% endif %}
  .logo-block .wordmark { font-size: 22px; }
  .stat-num { font-size: 52px; }
  .section--invert { margin: 0 -24px; padding: 44px 24px; }
}
</style>
</head>
<body>
<div class="wrap">

<div class="triple-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>

<!-- HERO -->
<div class="hero">
  <div class="issue-numeral" aria-hidden="true">{{ '%02d'|format(issue_num) }}</div>
  <div class="hero-content">
    <div class="hero-meta">{{ date_iso }} &nbsp;·&nbsp; CIRCUIT FERMÉ N°{{ "%02d"|format(issue_num) }} &nbsp;·&nbsp; {{ month_label }}</div>

    <div class="logo-block">
      <div class="lockup">
        <div class="signal-glyph" aria-hidden="true">
          <span class="sg-bar sg-r"></span>
          <span class="sg-bar sg-g"></span>
          <span class="sg-bar sg-b"></span>
        </div>
        <div class="lockup-text">
          <div class="wordmark">CIRCUIT</div>
          <div class="signal-label">Fermé</div>
        </div>
      </div>
      <div class="logo-mini-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>
      <div class="logo-collective">Underground Electronic · Paris</div>
    </div>

    <h1 class="tagline">{{ tagline_html | safe }}</h1>
    <div class="reading-time">{% if listening_time %}{{ reading_time }} lecture &nbsp;·&nbsp; {{ listening_time }} écoute{% else %}{{ reading_time }} &nbsp;·&nbsp; {{ month_label }}{% endif %}</div>
  </div>
</div>

<!-- SUMMARY -->
<div class="summary">
  <div class="lbl lbl-accent">Cette édition</div>
  <ul class="sum-list">
    {% for bullet in summary_bullets %}<li>{% if loop.index <= section_count %}<a class="sum-link" href="#s{{ loop.index }}">{{ bullet }}</a>{% else %}{{ bullet }}{% endif %}</li>
    {% endfor %}
  </ul>
  {% if listen_url %}<a class="listen-all" href="{{ listen_url }}" target="_blank" rel="noopener">▶ Écouter la sélection{% if listen_count %} · {{ listen_count }} tracks{% endif %}</a>{% endif %}
</div>

{#
  Le corps alterne sections et stats dans l'ordre fourni par `blocks`.
  Chaque bloc a un "type" : "section" (avec tracks ou body) ou "stat".
  Les sections "tracks" et "body" partagent la même enveloppe ; on choisit
  le rendu selon la présence de `tracks` ou `paragraphs`.
#}
{% for block in blocks %}
  {% if block.type == "section" %}
<div class="body-wrap">
<div class="section reveal{% if block.invert or block.heading == 'Note de studio' %} section--invert{% endif %}" id="s{{ block.index }}">
  <div class="s-accent"><div class="s-bar s-bar-{{ block.accent }}"></div><div class="s-num">{{ block.index }} / {{ section_count }}</div></div>
  <h2>{{ block.heading }}</h2>
    {% if block.tracks %}
  <div class="tracks tracks-{{ block.accent }}">
    {% for t in block.tracks %}
  <div class="track"{% if t.slug %} id="{{ t.slug }}"{% endif %}>
    <div class="track-name">{{ t.name }}</div>
    {% if t.label or t.catno or t.year %}<div class="track-meta">{{ t.label }}{% if t.catno %} {{ t.catno }}{% endif %}{% if t.format %} · {{ t.format }}{% endif %}{% if t.place %} · {{ t.place }}{% endif %}{% if t.year %} · {{ t.year }}{% endif %}</div>
    {% elif t.meta %}<div class="track-meta">{{ t.meta }}</div>{% endif %}
    <div class="track-body">{{ t.body | safe }}</div>
    {% if t.dig %}<div class="track-dig"><span class="dig-arrow">↳</span> {{ t.dig }}</div>{% endif %}
    {% if t.links %}
    <div class="track-links">
      {% for link in t.links %}<a class="track-link track-link-{{ block.accent }}" href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a>{% endfor %}
    </div>
    {% endif %}
  </div>
    {% endfor %}
  </div>
    {% endif %}
    {% if block.paragraphs %}
  <div class="s-body">
    {% for p in block.paragraphs %}<p>{{ p | safe }}</p>{% endfor %}
  </div>
    {% endif %}
</div>
</div>
  {% elif block.type == "stat" %}
<div class="stat stat-{{ block.accent }} reveal">
  <div class="stat-num">{{ block.number }}</div>
  <div class="stat-ctx">{{ block.context }}</div>
</div>
  {% endif %}
{% endfor %}

<!-- TRACKLIST RÉCAP (optionnel, flag racine show_tracklist) -->
{% if show_tracklist %}
<div class="body-wrap">
<div class="section reveal">
  <div class="lbl lbl-blue">Tracklist</div>
  <ol class="tracklist-recap-list">
    {% set ns = namespace(i=0) %}
    {% for block in blocks %}
      {% if block.tracks %}
        {% for t in block.tracks %}
          {% set ns.i = ns.i + 1 %}
  <li><a href="#{{ t.slug }}">{{ '%02d'|format(ns.i) }} {{ t.name }}</a></li>
        {% endfor %}
      {% endif %}
    {% endfor %}
  </ol>
</div>
</div>
{% endif %}

<!-- ÉCOUTER LA SÉLECTION (répété avant le forward) -->
{% if listen_url %}
<div class="listen-all-end-wrap">
  <a class="listen-all listen-all--end" href="{{ listen_url }}" target="_blank" rel="noopener">▶ Écouter la sélection{% if listen_count %} · {{ listen_count }} tracks{% endif %}</a>
</div>
{% endif %}

<!-- FORWARD -->
<div class="forward reveal">
  <div class="lbl lbl-red" style="margin-bottom:14px">Ce qui suit</div>
  <p>{{ forward_text | safe }}</p>
</div>

{% if site and site.membership_url %}
<!-- MEMBERSHIP (Membre du circuit · masqué tant que content/site.json n'a pas d'URL Stripe) -->
<div class="membership reveal">
  <div class="lbl lbl-accent">Soutenir</div>
  <h3 class="membership-title">Membre du circuit</h3>
  <p>La lettre reste gratuite. Les membres financent la suite et débloquent la Séance d'écoute mensuelle, le crate du mois avec ses tracks bonus, et l'objet de fin d'année pour les annuels.</p>
  <a class="membership-cta" href="{{ site.membership_url }}" target="_blank" rel="noopener">Devenir membre · {{ site.membership_price or '5 € / mois' }}</a>
  {% if site.membership_annual_url %}
  <div><a class="membership-alt" href="{{ site.membership_annual_url }}" target="_blank" rel="noopener">ou l'année · {{ site.membership_annual_price or '50 € / an' }}</a></div>
  {% endif %}
  <p class="membership-note">Sans engagement · résiliable en un clic.</p>
</div>
{% endif %}

<!-- SUBSCRIBE + QR (QR = partage à un ami, parcours honnête) -->
<div class="subscribe-section reveal">
  <div class="sub-text">
    <h3>Recevoir les prochaines issues</h3>
    <p>Notification push Android directement sur ton téléphone. Pas d'appli, pas de compte · Chrome + un tap.</p>
    <button id="sub-btn" onclick="subscribePush()">↓ S'abonner aux notifications</button>
    <p class="sub-note">Tu peux couper quand tu veux · une fois abonné·e, le même bouton sert à te désabonner.</p>
    <p id="sub-status" aria-live="polite"></p>
  </div>
  <button id="share-btn" hidden>↗ Partager à un ami</button>
  <div class="qr-wrap">
    <div class="qr-share-lbl">Partager à un ami</div>
    <img src="../../pwa/qr.png" alt="QR vers CIRCUIT FERMÉ" onerror="this.parentNode.style.display='none'">
    <div class="qr-steps">
      <span><b>1.</b> Scanne avec l'appareil photo</span>
      <span><b>2.</b> Ouvre le lien dans Chrome</span>
      <span><b>3.</b> Appuie sur « S'abonner »</span>
    </div>
  </div>
</div>

<!-- NAVIGATION D'ISSUE -->
<div class="issue-nav">
  <span class="issue-nav-prev">{% if prev_num %}<a href="../{{ prev_num }}/">← N°{{ prev_num }}</a>{% endif %}</span>
  <span class="issue-nav-all"><a href="../../">Tous les numéros</a></span>
  <span class="issue-nav-next">{% if next_num %}<a href="../{{ next_num }}/">N°{{ next_num }} →</a>{% endif %}</span>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-logo">
    <div class="footer-lockup">
      <div class="signal-glyph" aria-hidden="true">
        <span class="sg-bar sg-r"></span>
        <span class="sg-bar sg-g"></span>
        <span class="sg-bar sg-b"></span>
      </div>
      <div class="lockup-text">
        <div class="wordmark">CIRCUIT</div>
        <div class="signal-label">Fermé</div>
      </div>
    </div>
    <div class="footer-mini-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>
    <div class="footer-collective">Underground Electronic · Paris</div>
  </div>

  <div class="footer-credit">Sélection · KAPMAN</div>
  <div class="footer-links">
    <a class="footer-link" href="https://shotgun.live/artists/kapman_music" target="_blank" rel="noopener">Shotgun</a>
    <a class="footer-link" href="https://soundcloud.com/kapman_music" target="_blank" rel="noopener">SoundCloud</a>
    <a class="footer-link" href="https://www.instagram.com/kapman___/" target="_blank" rel="noopener">Instagram</a>
  </div>
  {% set track_count = blocks | selectattr('tracks', 'defined') | map(attribute='tracks') | map('length') | sum %}
  <div class="footer-colophon">N°{{ '%02d'|format(issue_num) }} · {{ month_label|upper }} · {{ track_count }} TRACKS · PARIS · CIRCUIT FERMÉ</div>
</div>

<div class="triple-rule"><span class="r"></span><span class="g"></span><span class="b"></span></div>

</div>
<script>
(function () {
  var root = document.documentElement;
  var els = [].slice.call(document.querySelectorAll('.reveal'));
  function showAll() { els.forEach(function (el) { el.classList.add('in'); }); }

  // On n'arme le masquage que si tout est OK ; sinon le contenu reste visible.
  var reduce = false;
  try { reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

  if (reduce || !('IntersectionObserver' in window)) {
    root.classList.add('js'); showAll(); return;
  }

  try {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });

    root.classList.add('js');           // masque (via CSS) puis révèle au scroll
    els.forEach(function (el) { io.observe(el); });

    // Révèle immédiatement ce qui est déjà dans le viewport au chargement.
    requestAnimationFrame(function () {
      els.forEach(function (el) {
        var r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('in');
      });
    });

    // Filet de sécurité : quoi qu'il arrive, tout est visible après 1,2 s.
    setTimeout(showAll, 1200);
  } catch (e) {
    root.classList.remove('js'); showAll();
  }

  // Le glyphe respire en continu, mais on le pause hors viewport (repos, pas de bruit gratuit).
  try {
    var hero = document.querySelector('.hero');
    var glyph = document.querySelector('.hero .signal-glyph');
    if (hero && glyph && 'IntersectionObserver' in window) {
      var heroIO = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          glyph.classList.toggle('paused', !e.isIntersecting);
        });
      }, { threshold: 0 });
      heroIO.observe(hero);
    }
  } catch (e) {}
})();
</script>
<script src="../../pwa/push-client.js"></script>
</body>
</html>
