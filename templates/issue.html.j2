{%- set listen_url = playlist_url or listen_all_url -%}
{%- import '_track.j2' as trackm -%}
{%- set site_url = "https://arochab.github.io/kapman-news/" -%}
{%- set issue_num_padded = "%02d"|format(issue_num) -%}
{%- set issue_url = site_url ~ "issues/" ~ issue_num_padded ~ "/" -%}
{%- set og_image_url = site_url ~ "issues/" ~ issue_num_padded ~ "/card.png" -%}
{%- set og_description = ((summary_bullets[0] if summary_bullets else (forward_text | striptags)) | trim) | truncate(160, True, "…") -%}
{#- date_iso "AAAA-MM-JJ" -> "JJ.MM.AA" : même registre que la home et la carte
    de partage. Fallback : la chaîne brute si le format est inattendu. -#}
{%- set date_display = date_iso[8:10] ~ "." ~ date_iso[5:7] ~ "." ~ date_iso[2:4] if date_iso and date_iso|length == 10 else date_iso -%}
{#-
  Numérotation continue des pièces (v5 « Index de sélection »). Un premier
  passage silencieux compte les pièces publiques (public_piece_total),
  utilisé comme dénominateur de « PIÈCE 0X/0N » sur chaque piste publique.
  total_pieces affine ce dénominateur avec les données du registre membre
  si présentes : circuit.total (numéro fermé, registre.pieces fourni par
  tools/circuit.py) ou circuit.count (anciens blobs sans "pieces", compte
  simple des pistes membres) ; sinon retombe sur public_piece_total (numéro
  entièrement public, rétrocompat totale).
-#}
{%- set pns0 = namespace(i=0) -%}
{%- for b in blocks -%}
  {%- for t in b.tracks or [] -%}{%- set pns0.i = pns0.i + 1 -%}{%- endfor -%}
{%- endfor -%}
{%- set public_piece_total = pns0.i -%}
{%- set total_pieces = public_piece_total -%}
{%- if circuit -%}
  {%- if circuit.pieces -%}
    {%- set total_pieces = circuit.total or (public_piece_total + circuit.pieces|length) -%}
  {%- elif circuit.count -%}
    {%- set total_pieces = public_piece_total + circuit.count -%}
  {%- endif -%}
{%- endif -%}
{#-
  public_true_idx[] : index GLOBAL (1..total_pieces) de chaque piste
  PUBLIQUE, dans l'ordre du document, en tenant compte des pièces membres
  ENTRELACÉES avant/entre elles (même algorithme que compute_pieces() dans
  tools/circuit.py, seule source de vérité). circuit.pieces donne l'idx
  global exact de chaque pièce membre ; les entiers de 1..total_pieces qui
  n'y figurent PAS sont, dans l'ordre, les idx des pistes publiques (l'ordre
  relatif de chaque flux, public et membre, est préservé par construction).
  Sans circuit.pieces (numéro sans circuit, ou vieux blob sans "pieces"),
  cette liste vaut simplement [1..total_pieces] : identique à un simple
  compteur séquentiel, comportement inchangé (rétrocompat totale).
-#}
{%- set member_idx_set = (circuit.pieces | map(attribute='idx') | list) if (circuit and circuit.pieces) else [] -%}
{%- set public_true_idx = [] -%}
{%- for i in range(1, total_pieces + 1) -%}
  {%- if i not in member_idx_set -%}
    {%- set _ = public_true_idx.append(i) -%}
  {%- endif -%}
{%- endfor -%}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CIRCUIT FERMÉ N°{{ "%02d"|format(issue_num) }} · {{ tagline_plain }}</title>
<meta name="theme-color" content="#FCFBF7">
<!-- Open Graph / Twitter Card : og_card.py génère issues/NN/card.png au build
     (tools/build_issue.py). og_image_available vient du contexte de rendu
     (og_card.py réussi) : si absent, aucune balise image n'est émise (pas
     de lien cassé), le reste (title/description/url) reste servi. -->
<meta property="og:type" content="article">
<meta property="og:locale" content="fr_FR">
<meta property="og:site_name" content="CIRCUIT FERMÉ">
<meta property="og:url" content="{{ issue_url }}">
<meta property="og:title" content="{{ tagline_plain }}">
<meta property="og:description" content="{{ og_description }}">
<meta name="twitter:title" content="{{ tagline_plain }}">
<meta name="twitter:description" content="{{ og_description }}">
{%- if og_image_available %}
<meta property="og:image" content="{{ og_image_url }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="CIRCUIT FERMÉ N°{{ issue_num_padded }} · {{ tagline_plain }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:image" content="{{ og_image_url }}">
{%- endif %}
<link rel="icon" href="../../pwa/icon-192.png" type="image/png">
<link rel="apple-touch-icon" href="../../pwa/icon-192.png">
<link rel="manifest" href="../../pwa/manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<!-- Charte v5 « Index de sélection » : DISPLAY + CORPS = Inter Tight
     (400/500/600/700/800) · TECHNIQUE (dates, catno, index, états, toute
     donnée) = B612 Mono (400/700). Fraunces/Space Grotesk/Space Mono
     retirées partout. -->
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700;800&family=B612+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* Charte v5 · tokens exacts (docs charte) : 4 rôles + papier, rien
     d'autre. Zéro hex hors :root. Le cycle or/cuivre/acier v4 disparaît :
     identité monochrome + rouge de strate uniquement. */
  --ivoire:    #FCFBF7; /* fond, la totalité des surfaces */
  --noir:      #121212; /* encre : texte, filets structurants, tampons, caviardage */
  --structure: #C8C5BC; /* structure secondaire : hairlines, séparateurs */
  --gris:      #6F6C64; /* texte secondaire, ≥4.5:1 sur ivoire */
  --rouge:     #D7261E; /* strate MEMBRE uniquement : tampon, étiquettes, caviardage au hover */
  --papier:    #F4F2EC; /* surfaces légères (note de studio) */

  --f-display: 'Inter Tight', Georgia, serif;
  --f-body:    'Inter Tight', system-ui, -apple-system, sans-serif;
  --f-mono:    'B612 Mono', ui-monospace, monospace;

  --fs-micro:   10.5px;
  --fs-kicker:  11.5px;
  --fs-meta:    13px;
  --fs-body:    17px;
  --fs-body-lg: 19px;
  --fs-h4:      19px;
  --fs-h3:      23px;
  --fs-h2:      33px;
  --fs-h1:      46px;

  --gutter: 40px;
}

html { background: var(--ivoire); scrollbar-color: var(--structure) var(--ivoire); }
body {
  background: var(--ivoire);
  color: var(--noir);
  font-family: var(--f-body);
  font-size: var(--fs-body);
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}

::selection { background: var(--noir); color: var(--ivoire); }

a { color: inherit; }
a:focus-visible, button:focus-visible, input:focus-visible { outline: 2px solid var(--noir); outline-offset: 3px; }

::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: var(--ivoire); }
::-webkit-scrollbar-thumb { background: var(--structure); border-radius: 6px; }
::-webkit-scrollbar-thumb:hover { background: var(--noir); }

.wrap { max-width: 720px; margin: 0 auto; }
.tnum { font-variant-numeric: tabular-nums; }

/* ── CARTOUCHES / ÉTIQUETTES DE STRATE ── */
.tag {
  display: inline-flex; align-items: center; gap: 5px;
  font-family: var(--f-mono); font-size: var(--fs-micro); font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase;
  border: 1px solid var(--noir); padding: 3px 8px 2px;
  color: var(--noir); background: transparent; line-height: 1.5;
}
.tag--membres { border-color: var(--rouge); color: var(--rouge); }
.tag--index { background: var(--noir); color: var(--ivoire); border-color: var(--noir); }

/* Micro-signe [CF] : rectangle, jamais un cercle (cf v4). */
.microsign {
  font-family: var(--f-mono); font-weight: 700; font-size: 13px;
  border: 1.5px solid var(--noir); padding: 5px 8px; display: inline-block;
  letter-spacing: .02em; color: var(--noir); line-height: 1;
}

/* ── HEADER ── */
.site-header {
  display: flex; align-items: baseline; justify-content: space-between; gap: 14px; flex-wrap: wrap;
  padding: 28px var(--gutter, 40px) 20px; border-bottom: 2px solid var(--noir);
}
.header-wordmark { font-family: var(--f-display); font-weight: 800; font-size: 18px; letter-spacing: -.005em; }
.header-meta { display: flex; align-items: center; gap: 10px; font-family: var(--f-mono); font-size: var(--fs-meta); color: var(--gris); letter-spacing: .02em; }

/* ── HERO ── */
.hero { padding: 40px var(--gutter, 40px) 44px; }
.hero-content { max-width: 620px; }
.edition-tag { display: flex; align-items: center; gap: 10px; margin-bottom: 22px; }
.tagline {
  font-family: var(--f-display); font-weight: 800; font-size: clamp(30px, 7.5vw, 54px);
  letter-spacing: -.01em; color: var(--noir); line-height: 1.1; margin-bottom: 18px;
}
.hero-sub { font-size: var(--fs-body-lg); color: var(--gris); line-height: 1.5; margin-bottom: 20px; max-width: 520px; }
.hero-meta { font-family: var(--f-mono); font-size: var(--fs-meta); letter-spacing: .04em; color: var(--gris); }
.hero-meta span { white-space: nowrap; }

/* ── SUMMARY ── */
.summary { padding: 0 var(--gutter, 40px) 40px; }
.kicker { font-family: var(--f-mono); font-size: var(--fs-kicker); letter-spacing: .14em; text-transform: uppercase; color: var(--noir); margin-bottom: 18px; font-weight: 700; }

.sum-list { list-style: none; border-top: 1px solid var(--noir); }
.sum-list li {
  padding: 14px 0 14px 20px; position: relative;
  font-size: 15px; color: var(--gris); border-bottom: 1px solid var(--structure);
}
.sum-list li::before { content: "·"; position: absolute; left: 0; color: var(--noir); font-weight: 700; }
.sum-link { color: inherit; text-decoration: none; display: block; transition: color .08s; }
.sum-link:hover, .sum-link:focus-visible { color: var(--noir); text-decoration: underline; }

.listen-all {
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--f-body); font-weight: 700; font-size: 15px; letter-spacing: .005em;
  color: var(--ivoire); background: var(--noir); border: 1px solid var(--noir);
  padding: 13px 24px; min-height: 44px; margin-top: 24px;
  text-decoration: none; transition: background .08s, color .08s;
}
.listen-all:hover, .listen-all:focus-visible { background: var(--ivoire); color: var(--noir); }
.listen-all-end-wrap { padding: 0 var(--gutter, 40px) 48px; }
.listen-all--end { margin-top: 0; }

/* ── BODY ── */
.body-wrap { padding: 0 var(--gutter, 40px); }

/* ── SECTION ── */
.section { padding: 48px 0; border-bottom: 1px solid var(--structure); }
.s-accent { display: flex; align-items: center; gap: 12px; margin-bottom: 22px; }
.s-num { font-family: var(--f-mono); font-size: var(--fs-meta); letter-spacing: .1em; text-transform: uppercase; color: var(--gris); }

.section h2 {
  font-family: var(--f-display); font-weight: 700; font-size: clamp(24px, 4vw, var(--fs-h2));
  letter-spacing: -.01em; color: var(--noir); line-height: 1.28; margin-bottom: 30px;
}

/* ── NOTE DE STUDIO (encart papier) ── */
.studio { background: var(--papier); border: 1px solid var(--structure); padding: 40px var(--gutter, 40px); margin: 0 var(--gutter, 40px) 0; }
.studio-label { font-family: var(--f-mono); font-size: var(--fs-kicker); letter-spacing: .14em; text-transform: uppercase; color: var(--noir); font-weight: 700; margin-bottom: 24px; }
.studio-body p { font-family: var(--f-display); font-weight: 500; font-size: var(--fs-h4); line-height: 1.6; color: var(--noir); margin-bottom: 18px; }
.studio-body p:last-child { margin-bottom: 0; }
.studio-sig { display: flex; justify-content: flex-end; margin-top: 28px; }

/* ── PIÈCE (registre public, "PIÈCE 01/07") ── */
.pieces { display: flex; flex-direction: column; gap: 32px; }
.piece { border: 1px solid var(--noir); padding: 20px 22px 24px; }
.piece:target { border-width: 2px; }
.piece-head { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
.piece-title { font-family: var(--f-body); font-weight: 700; font-size: 18px; line-height: 1.3; color: var(--noir); margin-bottom: 8px; }
.piece-meta { font-family: var(--f-mono); font-size: var(--fs-meta); color: var(--gris); letter-spacing: .02em; margin-bottom: 14px; line-height: 1.6; }
.piece-body { font-size: var(--fs-body); color: var(--noir); line-height: 1.6; margin-bottom: 12px; }
.piece-body strong { font-weight: 700; }
.piece-dig { font-size: 14.5px; line-height: 1.5; color: var(--gris); border-left: 2px solid var(--structure); padding-left: 12px; margin-bottom: 14px; }
.piece-dig .dig-arrow { font-family: var(--f-mono); color: var(--noir); margin-right: 4px; }
.piece-links { display: flex; flex-wrap: wrap; gap: 16px; }
.piece-link {
  font-family: var(--f-mono); font-size: 12.5px; font-weight: 700; letter-spacing: .04em;
  color: var(--noir); text-decoration: none; border-bottom: 1px solid transparent;
  min-height: 44px; display: inline-flex; align-items: center; transition: border-color .08s, color .08s;
}
.piece-link:hover, .piece-link:focus-visible { border-color: var(--noir); }

/* ── STAT (ligne de registre) ── */
.stat-row { padding: 40px var(--gutter, 40px); border-bottom: 1px solid var(--structure); background: var(--papier); }
.stat-num { font-family: var(--f-display); font-weight: 800; font-size: 48px; line-height: 1; letter-spacing: -.02em; color: var(--noir); margin-bottom: 12px; }
.stat-ctx { font-family: var(--f-mono); font-size: var(--fs-meta); color: var(--gris); line-height: 1.55; }

/* ── SECTION BODY ── */
.s-body p { font-size: var(--fs-body); color: var(--noir); line-height: 1.6; margin-bottom: 18px; }
.s-body p:last-child { margin-bottom: 0; }
.s-body a { color: var(--noir); text-decoration: none; border-bottom: 1px solid var(--noir); }
.s-body a:hover, .s-body a:focus-visible { color: var(--gris); }
.s-body strong { font-weight: 700; }

/* ── TRACKLIST RÉCAP (optionnel) ── */
.tracklist-recap-list { list-style: none; font-family: var(--f-mono); font-size: 12.5px; border-top: 1px solid var(--structure); }
.tracklist-recap-list li { border-bottom: 1px solid var(--structure); }
.tracklist-recap-list a { display: flex; align-items: center; padding: 12px 0; min-height: 44px; color: var(--gris); text-decoration: none; transition: color .08s; }
.tracklist-recap-list a:hover, .tracklist-recap-list a:focus-visible { color: var(--noir); }

/* ── FORWARD ── */
.forward { background: var(--papier); padding: 40px var(--gutter, 40px); border-top: 1px solid var(--structure); border-bottom: 1px solid var(--structure); }
.forward p { font-size: 15.5px; color: var(--gris); line-height: 1.6; }

/* ── LE REGISTRE ET LE CAVIARDAGE (cœur du système) ──
   Conditionné par `circuit` : seules les issues avec contenu membre
   embarquent ce CSS, rien n'en sort ailleurs (rétrocompat totale). */
{% if circuit %}
.registre {
  margin: 52px var(--gutter, 40px);
  border: 1px solid var(--noir);
  padding: 36px;
}
.registre-head { display: flex; align-items: center; gap: 10px; margin-bottom: 26px; flex-wrap: wrap; }
.registre-lines { border-top: 1px solid var(--noir); margin-bottom: 28px; }
.line-row {
  display: grid; grid-template-columns: 34px 1fr; gap: 14px; align-items: center;
  padding: 14px 0; border-bottom: 1px solid var(--structure);
}
.line-idx { font-family: var(--f-mono); font-size: 12.5px; font-weight: 700; color: var(--gris); }
.line-name { font-size: 15.5px; font-weight: 700; color: var(--noir); margin-bottom: 4px; line-height: 1.35; }
.line-meta { font-family: var(--f-mono); font-size: 11px; color: var(--gris); }
/* Caviardage : barre pleine noire, largeur pseudo-aléatoire stable par
   index (calculée en Jinja, --i pilote la cascade de retrait). Au
   déverrouillage la barre s'essuie (clip) puis se replie, et le nom injecté
   par pwa/circuit.js (.line-name--reveal) prend sa place, ligne à ligne. */
.redact-bar { display: block; height: 15px; background: var(--noir); margin: 4px 0 6px; clip-path: inset(0); }
.registre-open .line-locked .redact-bar {
  opacity: 0; clip-path: inset(0 0 0 100%); height: 0; margin: 0;
  transition: opacity .3s ease calc(var(--i, 0) * 80ms),
              clip-path .3s ease calc(var(--i, 0) * 80ms),
              height .2s ease calc(var(--i, 0) * 80ms + 240ms),
              margin .2s ease calc(var(--i, 0) * 80ms + 240ms);
}
.line-locked .line-name--reveal { opacity: 0; }
.registre-open .line-locked .line-name--reveal {
  opacity: 1;
  transition: opacity .3s ease calc(var(--i, 0) * 80ms + 180ms);
}

.stamp-row { display: flex; justify-content: center; padding: 4px 0 18px; }
.stamp {
  display: inline-block; font-family: var(--f-mono); font-weight: 700; font-size: 13px;
  letter-spacing: .16em; text-transform: uppercase; color: var(--rouge);
  border: 2px solid var(--rouge); padding: 7px 14px 5px; position: relative; background: var(--ivoire);
}
.stamp::after { content: ""; position: absolute; inset: 3px; border: 1px solid var(--rouge); pointer-events: none; }

.registre-note { font-size: 14.5px; line-height: 1.55; color: var(--gris); text-align: center; max-width: 420px; margin: 0 auto 22px; }

.circuit-form { display: flex; gap: 0; margin-bottom: 14px; }
.code-entry { flex: 1; border: 1px solid var(--noir); border-right: none; }
.code-entry input {
  width: 100%; border: none; background: transparent; font-family: var(--f-mono); font-size: 14px;
  padding: 13px 16px; color: var(--noir); letter-spacing: .06em; min-height: 44px;
}
.code-entry input::placeholder { color: var(--gris); }
.code-entry input:focus-visible { outline: 2px solid var(--noir); outline-offset: -2px; }
.btn-primary {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--noir); color: var(--ivoire); border: 1px solid var(--noir);
  font-family: var(--f-body); font-weight: 700; font-size: 15px; letter-spacing: .005em;
  padding: 13px 22px; min-height: 44px; cursor: pointer; transition: background .08s, color .08s;
}
.btn-primary:hover, .btn-primary:focus-visible { background: var(--ivoire); color: var(--noir); }
.circuit-error { font-family: var(--f-mono); font-size: 11px; color: var(--rouge); margin-top: 4px; text-align: center; display: none; }
.circuit-error.show { display: block; }

.circuit-membership {
  margin-top: 26px; padding-top: 22px; border-top: 1px solid var(--structure);
  display: flex; flex-wrap: wrap; align-items: center; gap: 10px 20px;
}
.circuit-membership-link {
  font-family: var(--f-body); font-size: 13.5px;
  color: var(--gris); text-decoration: none; padding: 4px 0; transition: color .08s;
}
.circuit-membership-link--primary { color: var(--noir); font-weight: 700; font-size: 14.5px; }
.circuit-membership-link:hover, .circuit-membership-link:focus-visible { color: var(--rouge); }

/* État déverrouillé : le tampon devient un cartouche « REGISTRE COMPLET ·
   MEMBRE », le champ (formulaire) disparaît. */
.circuit-open-line { display: none; justify-content: center; }
#circuit-lock.is-open .circuit-locked { display: none; }
#circuit-lock.is-open .circuit-open-line { display: flex; }
.tag--stamp-open { background: var(--rouge); border-color: var(--rouge); color: var(--ivoire); }

@media (max-width: 600px) {
  .registre { padding: 26px; margin: 40px 24px; }
  /* Le champ « Code du mois » garde sa largeur pleine : formulaire empilé,
     placeholder jamais tronqué, cibles pleine largeur. */
  .circuit-form { flex-direction: column; gap: 10px; }
  .code-entry { border-right: 1px solid var(--noir); }
  .circuit-form .btn-primary { width: 100%; }
}
{% endif %}

/* ── SUBSCRIBE (texte centré, QR centré en bas) ── */
.subscribe-section { padding: 60px var(--gutter, 40px); border-bottom: 1px solid var(--structure); text-align: center; }
.sub-text { max-width: 420px; margin: 0 auto; }
.sub-text h3 { font-family: var(--f-display); font-size: clamp(21px, 4vw, 25px); font-weight: 700; color: var(--noir); margin-bottom: 14px; }
.sub-text p { font-size: 14.5px; color: var(--gris); line-height: 1.6; margin-bottom: 26px; }
#sub-btn, #share-btn {
  font-family: var(--f-body); font-weight: 700; font-size: 15px; letter-spacing: .005em;
  color: var(--noir); background: transparent; border: 1px solid var(--noir);
  padding: 14px 26px; min-height: 44px; cursor: pointer; transition: background .08s, color .08s;
}
#sub-btn:hover, #sub-btn.on, #share-btn:hover { background: var(--noir); color: var(--ivoire); }
#share-btn { margin-top: 28px; }
.sub-note { font-family: var(--f-mono); font-size: 10px; color: var(--gris); line-height: 1.6; margin-top: 16px; letter-spacing: .02em; }
#sub-status { font-family: var(--f-mono); font-size: 12px; color: var(--gris); margin-top: 14px; min-height: 16px; line-height: 1.5; }
#sub-status[data-kind="ok"]  { color: var(--noir); font-weight: 700; }
#sub-status[data-kind="err"] { color: var(--rouge); }
.qr-wrap { margin: 44px auto 0; padding-top: 40px; border-top: 1px solid var(--structure); max-width: 260px; }
.qr-share-lbl { font-family: var(--f-mono); font-size: var(--fs-kicker); letter-spacing: .14em; text-transform: uppercase; color: var(--gris); margin-bottom: 18px; font-weight: 700; }
.qr-wrap img { width: 128px; height: 128px; display: block; margin: 0 auto 20px; image-rendering: pixelated; background: var(--ivoire); padding: 8px; border: 1px solid var(--structure); }
.qr-steps { display: inline-flex; flex-direction: column; gap: 8px; text-align: left; }
.qr-steps span { font-family: var(--f-mono); font-size: 11px; color: var(--gris); line-height: 1.4; }
.qr-steps b { color: var(--noir); font-weight: 700; margin-right: 6px; }

{% if site and site.membership_url %}
/* ── MEMBERSHIP (Le Circuit, optionnel) ── encart bordé rouge 1px, cartouche
   MEMBRES : tout ce bloc (CSS + markup) est conditionné par
   site.membership_url, comme avant. */
.membership { margin: 52px var(--gutter, 40px); border: 1px solid var(--rouge); padding: 44px; text-align: center; }
.membership-tag { display: flex; justify-content: center; margin-bottom: 20px; }
.membership-title { font-family: var(--f-display); font-size: clamp(23px, 4vw, 27px); font-weight: 700; color: var(--noir); margin-bottom: 14px; line-height: 1.3; }
.membership p { font-size: 15.5px; color: var(--gris); line-height: 1.6; max-width: 420px; margin: 0 auto 26px; }
.membership-cta {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--noir); color: var(--ivoire); border: 1px solid var(--noir);
  font-family: var(--f-body); font-weight: 700; font-size: 15px; letter-spacing: .005em;
  padding: 14px 26px; min-height: 44px; text-decoration: none; transition: background .08s, color .08s;
}
.membership-cta:hover, .membership-cta:focus-visible { background: var(--ivoire); color: var(--noir); }
.membership-alt { display: block; font-family: var(--f-body); font-size: 13.5px; color: var(--gris); text-decoration: underline; margin-top: 16px; }
.membership-alt:hover, .membership-alt:focus-visible { color: var(--noir); }
.membership-note { font-family: var(--f-mono); font-size: 10px; color: var(--gris); margin-top: 16px; letter-spacing: .04em; }
{% endif %}

/* ── NAVIGATION D'ISSUE ── */
.issue-nav {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22px var(--gutter, 40px); border-top: 1px solid var(--structure);
  font-family: var(--f-mono); font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
}
.issue-nav a { color: var(--gris); text-decoration: none; display: inline-flex; align-items: center; min-height: 44px; transition: color .08s; }
.issue-nav a:hover, .issue-nav a:focus-visible { color: var(--noir); }
.issue-nav-prev, .issue-nav-next { flex: 1; }
.issue-nav-next { text-align: right; justify-content: flex-end; }
.issue-nav-next a { justify-content: flex-end; }
.issue-nav-all { flex: 1; text-align: center; }
.issue-nav-all a { justify-content: center; }

/* ── FOOTER ── */
.footer { padding: 48px var(--gutter, 40px) 56px; text-align: center; border-top: 2px solid var(--noir); }
.footer-seal { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 24px; }
.footer-seal .header-wordmark { font-size: 13px; }
.footer-credit { font-family: var(--f-mono); font-size: 10px; color: var(--gris); line-height: 1.6; margin-bottom: 6px; letter-spacing: .04em; }
.footer-links { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 4px; margin-bottom: 10px; }
.footer-link { font-family: var(--f-mono); font-size: 10px; letter-spacing: .06em; text-transform: uppercase; color: var(--gris); text-decoration: none; padding: 17px 12px; display: inline-flex; align-items: center; transition: color .08s; }
.footer-link:hover, .footer-link:focus-visible { color: var(--noir); }
.footer-colophon { font-family: var(--f-mono); font-size: 10px; color: var(--gris); letter-spacing: .06em; text-transform: uppercase; line-height: 1.6; }

/* ── MOTION ── reveal : opacity seule, 240ms, pas de translation. Le seul
   autre mouvement du site est la cascade de caviardage ci-dessus. */
.js .reveal { opacity: 0; transition: opacity .24s ease; }
.js .reveal.in { opacity: 1; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .001ms !important; animation-iteration-count: 1 !important; transition-duration: .001ms !important; scroll-behavior: auto !important; }
  .js .reveal { opacity: 1 !important; }
}

@media (max-width: 600px) {
  :root { --gutter: 24px; }
  .site-header { padding-top: 24px; padding-bottom: 18px; }
  .stat-num { font-size: 40px; }
  .studio { margin: 0 24px 0; padding: 28px 24px; }
  {% if site and site.membership_url %}.membership { padding: 32px 24px; }{% endif %}
}
</style>
</head>
<body>
<div class="wrap">

<!-- HEADER -->
<header class="site-header">
  <div class="header-wordmark">CIRCUIT FERMÉ</div>
  <div class="header-meta tnum"><span class="tag">Public</span> {{ date_display }}</div>
</header>

<!-- HERO -->
<div class="hero" data-flow="0">
  <div class="hero-content">
    <div class="edition-tag"><span class="tag tag--index tnum">ÉD. {{ '%03d'|format(issue_num) }}</span> <span class="tag">Public</span></div>
    <h1 class="tagline">{{ tagline_html | safe }}</h1>
    <div class="hero-meta tnum"><span>{{ date_display }}</span> {% if listening_time %}<span>· Lecture {{ reading_time }}</span> <span>· Écoute {{ listening_time }}</span>{% else %}<span>· Lecture {{ reading_time }}</span>{% endif %}</div>
  </div>
</div>

<!-- SUMMARY -->
<div class="summary">
  <div class="kicker">Cette édition</div>
  <ul class="sum-list">
    {% for bullet in summary_bullets %}<li>{% if loop.index <= section_count %}<a class="sum-link" href="#s{{ loop.index }}">{{ bullet }}</a>{% else %}{{ bullet }}{% endif %}</li>
    {% endfor %}
  </ul>
  {% if listen_url %}<a class="listen-all" href="{{ listen_url }}" target="_blank" rel="noopener">▶ Écouter la sélection</a>{% endif %}
</div>

{#
  Le corps alterne sections et stats dans l'ordre fourni par `blocks`.
  Chaque bloc a un "type" : "section" (avec tracks ou body) ou "stat".
  Les tracks publiques reçoivent leur index global continu (pns.i, 1..N)
  pour "PIÈCE 0X/0N" ; le compteur n'est jamais remis à zéro entre sections.
#}
{%- set pns = namespace(i=0) -%}
{% for block in blocks %}
  {% if block.type == "section" and block.heading == 'Note de studio' %}
<div class="body-wrap" data-flow="{{ loop.index }}">
<div class="section studio reveal" id="s{{ block.index }}">
  <div class="studio-label">Note de studio · {{ month_label }}</div>
  <div class="studio-body">
    {% for p in block.paragraphs %}<p>{{ p | safe }}</p>{% endfor %}
  </div>
  <div class="studio-sig"><span class="microsign">CF</span></div>
</div>
</div>
  {% elif block.type == "section" %}
<div class="body-wrap" data-flow="{{ loop.index }}">
<div class="section reveal" id="s{{ block.index }}">
  <div class="s-accent"><span class="s-num tnum">{{ '%02d'|format(block.index) }} / {{ '%02d'|format(section_count) }}</span></div>
  <h2>{{ block.heading }}</h2>
    {% if block.tracks %}
  <div class="pieces">
    {% for t in block.tracks %}
{%- set pns.i = pns.i + 1 -%}
{%- set piece_idx = public_true_idx[pns.i - 1] if public_true_idx|length >= pns.i else pns.i -%}
{{ trackm.track(t, piece_idx, total_pieces, 'public') }}
    {% endfor %}
  </div>
    {% endif %}
    {% if block.paragraphs %}
  <div class="s-body">
    {% for p in block.paragraphs %}<p>{{ p | safe }}</p>{% endfor %}
  </div>
    {% endif %}
</div>
</div>
  {% elif block.type == "stat" %}
<div class="stat-row reveal" data-flow="{{ loop.index }}">
  <div class="stat-num tnum">{{ block.number }}</div>
  <div class="stat-ctx">{{ block.context }}</div>
</div>
  {% endif %}
{% endfor %}
{% if circuit %}
<!-- LE REGISTRE ET LE CAVIARDAGE = LA CARTE DE MEMBRE -->
<div class="body-wrap">
<div id="circuit-lock" class="registre reveal">
  {% if circuit.pieces %}
  {#-
    Le registre liste TOUTES les pièces (publiques + membres) en un seul
    flux continu 01..0N dans leur ordre GLOBAL réel (cf public_true_idx
    ci-dessus + circuit.pieces[].idx), pas les publiques puis les membres
    à la suite : line_by_idx associe chaque idx global à sa ligne (nom en
    clair si publique, barre de caviardage si membre), rendu en parcourant
    1..total_pieces dans l'ordre.
  -#}
  {%- set line_by_idx = {} -%}
  {%- set lns = namespace(i=0) -%}
  {%- for b in blocks -%}
    {%- for t in b.tracks or [] -%}
      {%- set lns.i = lns.i + 1 -%}
      {%- set true_i = public_true_idx[lns.i - 1] if public_true_idx|length >= lns.i else lns.i -%}
      {%- set _ = line_by_idx.update({true_i: {"name": t.name, "meta": trackm.meta(t), "locked": false}}) -%}
    {%- endfor -%}
  {%- endfor -%}
  {%- for piece in circuit.pieces -%}
    {%- set _ = line_by_idx.update({piece.idx: {"piece": piece, "locked": true}}) -%}
  {%- endfor -%}
  <div class="registre-head">
    <span class="tag tag--index tnum">Registre complet</span>
    <span class="tag tnum">{{ '%02d'|format(total_pieces) }} pièces</span>
  </div>
  <div class="registre-lines">
    {%- set lock_ns = namespace(n=0) -%}
    {% for i in range(1, total_pieces + 1) %}
      {%- set line = line_by_idx.get(i) -%}
      {% if line and line.locked %}
        {%- set lock_ns.n = lock_ns.n + 1 -%}
    <div class="line-row line-locked" style="--i:{{ lock_ns.n - 1 }}">
      <div class="line-idx tnum">{{ '%02d'|format(i) }}</div>
      <div>
        <span class="redact-bar" style="width:{{ ((i * 53) % 46) + 40 }}%"></span>
        <div class="line-meta tnum">{{ line.piece.format }}{% if line.piece.format and line.piece.year %} · {% endif %}{{ line.piece.year }}</div>
      </div>
    </div>
      {% elif line %}
    <div class="line-row">
      <div class="line-idx tnum">{{ '%02d'|format(i) }}</div>
      <div>
        <div class="line-name">{{ line.name }}</div>
        {% if line.meta %}<div class="line-meta tnum">{{ line.meta }}</div>{% endif %}
      </div>
    </div>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  <div class="circuit-locked">
    <div class="stamp-row"><span class="stamp">Réservé</span></div>
    <p class="registre-note">{{ circuit.teaser or "La suite de ce numéro reste dans le circuit, réservée aux membres." }}</p>
    <form id="circuit-form" class="circuit-form" autocomplete="off">
      <div class="code-entry"><input id="circuit-code" type="text" autocomplete="off" placeholder="Code du mois" aria-label="Code du circuit"></div>
      <button type="submit" class="btn-primary">Entrer le code</button>
    </form>
    <p class="circuit-error" role="alert">Ce code n'ouvre rien.</p>
    {% if site and site.membership_url %}
    <div class="circuit-membership">
      <span class="tag tag--membres">Membres</span>
      <a class="circuit-membership-link circuit-membership-link--primary" href="{{ site.membership_url }}" target="_blank" rel="noopener">Devenir membre · {{ site.membership_price or '5 € par mois' }}</a>
      {% if site.membership_annual_url %}<a class="circuit-membership-link" href="{{ site.membership_annual_url }}" target="_blank" rel="noopener">ou {{ site.membership_annual_price or "50 € l'année" }}, l'objet de décembre compris</a>{% endif %}
    </div>
    {% endif %}
  </div>
  <div class="circuit-open-line">
    <span class="tag tag--stamp-open tnum">Registre complet · membre</span>
  </div>
</div>
</div>
<script type="application/json" id="circuit-blob">{{ circuit | tojson }}</script>
{% endif %}
<!-- TRACKLIST RÉCAP (optionnel, flag racine show_tracklist) -->
{% if show_tracklist %}
<div class="body-wrap">
<div class="section reveal">
  <div class="kicker">Tracklist</div>
  <ol class="tracklist-recap-list">
    {% set ns = namespace(i=0) %}
    {% for block in blocks %}
      {% if block.tracks %}
        {% for t in block.tracks %}
          {% set ns.i = ns.i + 1 %}
  <li><a href="#{{ t.slug }}">{{ '%02d'|format(ns.i) }} {{ t.name }}</a></li>
        {% endfor %}
      {% endif %}
    {% endfor %}
  </ol>
</div>
</div>
{% endif %}

<!-- ÉCOUTER LA SÉLECTION (répété avant le forward) -->
{% if listen_url %}
<div class="listen-all-end-wrap">
  <a class="listen-all listen-all--end" href="{{ listen_url }}" target="_blank" rel="noopener">▶ Écouter la sélection</a>
</div>
{% endif %}

<!-- FORWARD -->
<div class="forward reveal">
  <div class="kicker" style="margin-bottom:14px">Ce qui suit</div>
  <p>{{ forward_text | safe }}</p>
</div>

{% if site and site.membership_url and not circuit %}
<!-- MEMBERSHIP (Le Circuit · masqué tant que content/site.json n'a pas d'URL Stripe,
     ou si l'issue a un circuit fermé : la version compacte est déjà dans le registre) -->
<div class="membership reveal">
  <div class="membership-tag"><span class="tag tag--membres">Membres</span></div>
  <h3 class="membership-title">Le Circuit</h3>
  <p>La lettre publique reste gratuite. Les membres débloquent le reste de chaque numéro fermé, le crate du mois avec ses tracks bonus, et l'objet de fin d'année pour les annuels.</p>
  <a class="membership-cta" href="{{ site.membership_url }}" target="_blank" rel="noopener">Devenir membre · {{ site.membership_price or '5 € par mois' }}</a>
  {% if site.membership_annual_url %}
  <div><a class="membership-alt" href="{{ site.membership_annual_url }}" target="_blank" rel="noopener">ou {{ site.membership_annual_price or "50 € l'année" }}, l'objet de décembre compris</a></div>
  {% endif %}
  <p class="membership-note">Sans engagement · résiliable en un clic.</p>
</div>
{% endif %}

<!-- SUBSCRIBE + QR (QR = partage à un ami, parcours honnête) -->
<div class="subscribe-section reveal">
  <div class="sub-text">
    <h3>Recevoir les prochaines éditions</h3>
    <p>Une notification sur votre téléphone Android, deux fois par semaine. Pas d'application, pas de compte&nbsp;: Chrome suffit.</p>
    <button id="sub-btn" onclick="subscribePush()">↓ S'abonner aux notifications</button>
    <p class="sub-note">Vous pouvez couper quand vous voulez · le même bouton sert à vous désabonner.</p>
    <p id="sub-status" aria-live="polite"></p>
  </div>
  <button id="share-btn" hidden>↗ Partager à un ami</button>
  <div class="qr-wrap">
    <div class="qr-share-lbl">Partager à un ami</div>
    <img src="../../pwa/qr.png" alt="QR vers CIRCUIT FERMÉ" onerror="this.parentNode.style.display='none'">
    <div class="qr-steps">
      <span><b>1.</b> Scannez avec l'appareil photo</span>
      <span><b>2.</b> Ouvrez le lien dans Chrome</span>
      <span><b>3.</b> Appuyez sur « S'abonner »</span>
    </div>
  </div>
</div>

<!-- NAVIGATION D'ISSUE -->
<div class="issue-nav">
  <span class="issue-nav-prev">{% if prev_num %}<a href="../{{ prev_num }}/">← N°{{ prev_num }}</a>{% endif %}</span>
  <span class="issue-nav-all"><a href="../../">Tous les numéros</a></span>
  <span class="issue-nav-next">{% if next_num %}<a href="../{{ next_num }}/">N°{{ next_num }} →</a>{% endif %}</span>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-seal">
    <span class="microsign">CF</span>
    <div class="header-wordmark">CIRCUIT FERMÉ</div>
  </div>

  <div class="footer-credit">Sélection · KAPMAN</div>
  <div class="footer-links">
    <a class="footer-link" href="https://shotgun.live/artists/kapman_music" target="_blank" rel="noopener">Shotgun</a>
    <a class="footer-link" href="https://soundcloud.com/kapman_music" target="_blank" rel="noopener">SoundCloud</a>
    <a class="footer-link" href="https://www.instagram.com/kapman___/" target="_blank" rel="noopener">Instagram</a>
  </div>
  <div class="footer-colophon">N°{{ '%02d'|format(issue_num) }} · {{ month_label|upper }} · {{ total_pieces }} PIÈCE{{ 'S' if total_pieces != 1 }} · PARIS · CIRCUIT FERMÉ · REGISTRE DES SÉLECTIONS</div>
</div>

</div>
<script>
(function () {
  var root = document.documentElement;
  var els = [].slice.call(document.querySelectorAll('.reveal'));
  function showAll() { els.forEach(function (el) { el.classList.add('in'); }); }

  // On n'arme le masquage que si tout est OK ; sinon le contenu reste visible.
  var reduce = false;
  try { reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

  if (reduce || !('IntersectionObserver' in window)) {
    root.classList.add('js'); showAll(); return;
  }

  try {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });

    root.classList.add('js');           // masque (via CSS) puis révèle au scroll
    els.forEach(function (el) { io.observe(el); });

    // Révèle immédiatement ce qui est déjà dans le viewport au chargement.
    requestAnimationFrame(function () {
      els.forEach(function (el) {
        var r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('in');
      });
    });

    // Filet de sécurité : quoi qu'il arrive, tout est visible après 1,2 s.
    setTimeout(showAll, 1200);
  } catch (e) {
    root.classList.remove('js'); showAll();
  }
})();
</script>
{% if circuit %}<script src="../../pwa/circuit.js" defer></script>
{% endif -%}
<script src="../../pwa/push-client.js"></script>
</body>
</html>
